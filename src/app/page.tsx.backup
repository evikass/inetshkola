// ==================== ПРЕОБРАЗОВАНИЕ ДАННЫХ В ИЕРАРХИЮ ====================
// Функция для группировки тем в разделы и темы
interface TopicLegacy {
  id: string
  title: string
  description: string
  theory: string
  examples: string[]
  completed: boolean
  difficulty: 'easy' | 'medium' | 'hard'
  estimatedTime: number
}

interface SubjectLegacy {
  id: string
  title: string
  icon: React.ReactNode
  color: string
  gradient: string
  description: string
  topics: TopicLegacy[]
  quiz: QuizQuestion[]
}

interface GradeLegacy {
  id: number
  name: string
  shortName: string
  subjects: SubjectLegacy[]
}

// Правила группировки тем по разделам и темам для каждого предмета
