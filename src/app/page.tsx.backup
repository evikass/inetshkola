// ==================== ТИПЫ ДАННЫХ ====================
// Урок - самый низкий уровень
interface Lesson {
  id: string
  title: string
  description: string
  theory: string
  examples: string[]
  completed: boolean
  difficulty: 'easy' | 'medium' | 'hard'
  estimatedTime: number // в минутах
}

// Тема - содержит уроки
interface Topic {
  id: string
  title: string
  description: string
  icon?: React.ReactNode
  lessons: Lesson[]
}

// Раздел - содержит темы
interface Section {
  id: string
  title: string
  description: string
  icon?: React.ReactNode
  topics: Topic[]
}

interface QuizQuestion {
  id: string
  question: string
  options: string[]
  correctAnswer: number
  explanation: string
  difficulty: 'easy' | 'medium' | 'hard'
  points: number
}

interface Subject {
  id: string
  title: string
  icon: React.ReactNode
  color: string
  gradient: string
  description: string
  sections: Section[]
  topics?: Lesson[] // Для обратной совместимости с исходными данными
  quiz?: QuizQuestion[]
}

interface Grade {
  id: number
  name: string
  shortName: string
  subjects: Subject[]
}

interface Achievement {
  id: string
  title: string
  description: string
  icon: React.ReactNode
  unlocked: boolean
  unlockedAt?: string
  condition: string
  points: number
  rarity: 'common' | 'rare' | 'epic' | 'legendary'
}

interface DailyTask {
  id: string
  title: string
  description: string
  target: number
  progress: number
  reward: number
  completed: boolean
  type: 'topics' | 'quizzes' | 'points'
}

interface UserStats {
  level: number
  experience: number
  totalPoints: number
  topicsCompleted: number
  quizzesCompleted: number
  perfectQuizzes: number
  streak: number
  maxStreak: number
  lastActiveDate: string
  totalStudyTime: number
  rank: string
}

interface ActivityLogItem {
  id: string
  type: 'topic' | 'quiz' | 'achievement' | 'streak'
  title: string
  timestamp: string
  points: number
}

interface DailyStats {
  topicsToday: number
  quizzesToday: number
  pointsToday: number
  timeToday: number // в минутах
}

