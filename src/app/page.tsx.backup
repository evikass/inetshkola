  // Эпические достижения
  { id: 'all_classes', title: 'Все классы', description: 'Откройте все классы', icon: <Crown className="w-6 h-6" />, unlocked: false, condition: 'visit_all_classes', points: 250, rarity: 'epic' },
  { id: 'streak_30', title: 'Месяц знаний', description: 'Занимайтесь 30 дней подряд', icon: <Flame className="w-6 h-6" />, unlocked: false, condition: '30_day_streak', points: 700, rarity: 'epic' },
  { id: 'knowledge_seeker', title: 'Искатель знаний', description: 'Изучите 200 тем', icon: <BookOpen className="w-6 h-6" />, unlocked: false, condition: '200_topics', points: 800, rarity: 'epic' },
  { id: 'perfect_ten', title: '10 из 10', description: 'Получите 100% в 10 квизах', icon: <Medal className="w-6 h-6" />, unlocked: false, condition: '10_perfect', points: 600, rarity: 'epic' },
  { id: 'challenge_master', title: 'Мастер челленджей', description: 'Пройдите 30 ежедневных челленджей', icon: <Zap className="w-6 h-6" />, unlocked: false, condition: '30_challenges', points: 500, rarity: 'epic' },
  
  // Легендарные достижения
  { id: 'genius', title: 'Гений', description: 'Изучите все темы', icon: <Sparkles className="w-6 h-6" />, unlocked: false, condition: 'complete_all', points: 1000, rarity: 'legendary' },
  { id: 'streak_100', title: 'Легенда', description: 'Занимайтесь 100 дней подряд', icon: <Crown className="w-6 h-6" />, unlocked: false, condition: '100_day_streak', points: 2000, rarity: 'legendary' },
  { id: 'perfectionist', title: 'Перфекционист', description: 'Получите 100% в 50 квизах', icon: <Medal className="w-6 h-6" />, unlocked: false, condition: '50_perfect', points: 1500, rarity: 'legendary' },
  { id: 'grandmaster', title: 'Грандмастер', description: 'Достигните 100 уровня', icon: <Crown className="w-6 h-6" />, unlocked: false, condition: 'level_100', points: 2000, rarity: 'legendary' }
]

// Ежедневные задания
const dailyTasksData: DailyTask[] = [
  { id: 'daily_topics', title: 'Изучить темы', description: 'Изучите 3 темы сегодня', target: 3, progress: 0, reward: 30, completed: false, type: 'topics' },
  { id: 'daily_quiz', title: 'Пройти тест', description: 'Пройдите 1 квиз сегодня', target: 1, progress: 0, reward: 25, completed: false, type: 'quizzes' },
  { id: 'daily_points', title: 'Набрать очки', description: 'Наберите 50 очков сегодня', target: 50, progress: 0, reward: 20, completed: false, type: 'points' },
  { id: 'daily_challenge', title: 'Ежедневный челлендж', description: 'Пройдите ежедневный челлендж', target: 1, progress: 0, reward: 40, completed: false, type: 'challenges' }
]

// ==================== ГЛАВНЫЙ КОМПОНЕНТ ====================
export default function SchoolApp() {
  // Состояния
  const [selectedGrade, setSelectedGrade] = useState(1)
  const [searchQuery, setSearchQuery] = useState('')
  const [progress, setProgress] = useState<Record<string, Record<string, boolean>>>({})
  const [userStats, setUserStats] = useState<UserStats>({
    level: 1,
    experience: 0,
    totalPoints: 0,
    topicsCompleted: 0,
    quizzesCompleted: 0,
    perfectQuizzes: 0,
    streak: 0,
    maxStreak: 0,
    lastActiveDate: '',
    totalStudyTime: 0,
    rank: 'Новичок'
  })
  const [achievements, setAchievements] = useState<Achievement[]>(achievementsData)
  const [dailyTasks, setDailyTasks] = useState<DailyTask[]>(dailyTasksData)
  const [quizDialogOpen, setQuizDialogOpen] = useState(false)
  const [currentQuiz, setCurrentQuiz] = useState<QuizQuestion[]>([])
  const [currentQuizSubject, setCurrentQuizSubject] = useState<string>('')
  const [currentQuestionIndex, setCurrentQuestionIndex] = useState(0)
  const [selectedAnswer, setSelectedAnswer] = useState<number | null>(null)
  const [showResult, setShowResult] = useState(false)
  const [quizScore, setQuizScore] = useState(0)
  const [activeTab, setActiveTab] = useState('subjects')
  const [expandedSubject, setExpandedSubject] = useState<string | null>(null)
  const [selectedTopic, setSelectedTopic] = useState<Topic | null>(null)
  const [selectedSubjectForTopic, setSelectedSubjectForTopic] = useState<Subject | null>(null)
  const [topicDialogOpen, setTopicDialogOpen] = useState(false)
  const [visitedClasses, setVisitedClasses] = useState<Set<number>>(new Set([1]))
  const [showConfetti, setShowConfetti] = useState(false)
  const [showShortcuts, setShowShortcuts] = useState(false)
  const [activityLog, setActivityLog] = useState<ActivityLogItem[]>([])
  const [dailyStats, setDailyStats] = useState<DailyStats>({
    topicsToday: 0,
    quizzesToday: 0,
    pointsToday: 0,
    timeToday: 0
  })
  const [streakFreeze, setStreakFreeze] = useState(3) // Заморозки стрика
  const [soundEnabled, setSoundEnabled] = useState(true) // Звук
  const [showSettings, setShowSettings] = useState(false) // Настройки
  const [studyTime, setStudyTime] = useState(0) // Таймер в секундах
  const [isTimerRunning, setIsTimerRunning] = useState(false)
  const [bookmarks, setBookmarks] = useState<string[]>([]) // Избранные темы
  const [notes, setNotes] = useState<Record<string, string>>({}) // Заметки
  
  // Состояния для режима карточек
  const [flashcardMode, setFlashcardMode] = useState(false)
  const [currentFlashcardIndex, setCurrentFlashcardIndex] = useState(0)
  const [isFlipped, setIsFlipped] = useState(false)
  const [flashcards, setFlashcards] = useState<{question: string, answer: string, subject: string}[]>([])
  const [flashcardStats, setFlashcardStats] = useState<{known: number, unknown: number}>({known: 0, unknown: 0})
  
  // Состояния для режима экзамена
  const [examMode, setExamMode] = useState(false)
  const [examQuestions, setExamQuestions] = useState<QuizQuestion[]>([])
  const [examAnswers, setExamAnswers] = useState<number[]>([])
  const [examTimer, setExamTimer] = useState(0)
  const [examSubject, setExamSubject] = useState<string>('all')
  const [examGrade, setExamGrade] = useState<number | null>(null)
  const [examCorrectAnswers, setExamCorrectAnswers] = useState<number[]>([])
  const [showExamResults, setShowExamResults] = useState(false)
  
  // Состояния для ежедневного челленджа
  const [challengeMode, setChallengeMode] = useState(false)
  const [challengeQuestions, setChallengeQuestions] = useState<QuizQuestion[]>([])
  const [challengeIndex, setChallengeIndex] = useState(0)
  const [challengeScore, setChallengeScore] = useState(0)
  const [challengeCompleted, setChallengeCompleted] = useState(false)
  const [dailyChallengeDone, setDailyChallengeDone] = useState(false)
  
  // Дополнительные состояния для достижений
  const [perfectQuizzesCount, setPerfectQuizzesCount] = useState(0)
  const [totalChallengesCompleted, setTotalChallengesCompleted] = useState(0)
  
  // Комбо-система
  const [currentCombo, setCurrentCombo] = useState(0)
  const [maxCombo, setMaxCombo] = useState(0)
  
  // XP бустеры
  const [xpBooster, setXpBooster] = useState(1)
  const [boosterEndTime, setBoosterEndTime] = useState<Date | null>(null)
  
  // Недавние темы
  const [recentTopics, setRecentTopics] = useState<string[]>([])

  // Загрузка данных из localStorage
  useEffect(() => {
    const savedProgress = localStorage.getItem('schoolProgress_v2')
    const savedStats = localStorage.getItem('schoolStats_v2')
    const savedAchievements = localStorage.getItem('schoolAchievements_v2')
    const savedVisited = localStorage.getItem('visitedClasses_v2')
    const savedTasks = localStorage.getItem('dailyTasks_v2')
    const savedLastDate = localStorage.getItem('lastActiveDate_v2')
    const savedActivityLog = localStorage.getItem('activityLog_v2')
    const savedDailyStats = localStorage.getItem('dailyStats_v2')
    const savedStreakFreeze = localStorage.getItem('streakFreeze_v2')
    const savedBookmarks = localStorage.getItem('bookmarks_v2')
    const savedNotes = localStorage.getItem('notes_v2')
    const savedStudyTime = localStorage.getItem('studyTime_v2')
    const savedDailyChallenge = localStorage.getItem('dailyChallengeDone_v2')
    const savedPerfectQuizzes = localStorage.getItem('perfectQuizzesCount_v2')
    const savedTotalChallenges = localStorage.getItem('totalChallengesCompleted_v2')
    const savedCurrentCombo = localStorage.getItem('currentCombo_v2')
    const savedMaxCombo = localStorage.getItem('maxCombo_v2')
    const savedRecentTopics = localStorage.getItem('recentTopics_v2')
    
    if (savedProgress) setProgress(JSON.parse(savedProgress))
    if (savedStats) setUserStats(JSON.parse(savedStats))
    // Для достижений загружаем только статус разблокировки и объединяем с исходными данными
    if (savedAchievements) {
      try {
        const savedUnlockStatus = JSON.parse(savedAchievements)
        const mergedAchievements = achievementsData.map(a => {
          const saved = savedUnlockStatus.find((s: {id: string}) => s.id === a.id)
          return saved ? { ...a, unlocked: saved.unlocked, unlockedAt: saved.unlockedAt } : a
        })
        setAchievements(mergedAchievements)
      } catch {
        // Если ошибка парсинга, используем исходные данные
      }
    }
    if (savedVisited) setVisitedClasses(new Set(JSON.parse(savedVisited)))
    if (savedTasks) setDailyTasks(JSON.parse(savedTasks))
    if (savedActivityLog) setActivityLog(JSON.parse(savedActivityLog))
    if (savedDailyStats) setDailyStats(JSON.parse(savedDailyStats))
    if (savedStreakFreeze) setStreakFreeze(JSON.parse(savedStreakFreeze))
    if (savedBookmarks) setBookmarks(JSON.parse(savedBookmarks))
    if (savedNotes) setNotes(JSON.parse(savedNotes))
    if (savedStudyTime) setStudyTime(JSON.parse(savedStudyTime))
    if (savedDailyChallenge) setDailyChallengeDone(JSON.parse(savedDailyChallenge))
    if (savedPerfectQuizzes) setPerfectQuizzesCount(JSON.parse(savedPerfectQuizzes))
    if (savedTotalChallenges) setTotalChallengesCompleted(JSON.parse(savedTotalChallenges))
    if (savedCurrentCombo) setCurrentCombo(JSON.parse(savedCurrentCombo))
    if (savedMaxCombo) setMaxCombo(JSON.parse(savedMaxCombo))
    if (savedRecentTopics) setRecentTopics(JSON.parse(savedRecentTopics))
    
    // Проверка стрика
    const today = new Date().toDateString()
    const lastDate = savedLastDate || ''
    
    if (lastDate !== today) {
      const yesterday = new Date()
      yesterday.setDate(yesterday.getDate() - 1)
      
      if (lastDate === yesterday.toDateString()) {
        // Продолжение стрика
        setUserStats(prev => ({
          ...prev,
          streak: prev.streak + 1,
          maxStreak: Math.max(prev.maxStreak, prev.streak + 1),
          lastActiveDate: today
        }))
      } else if (lastDate !== '') {
        // Сброс стрика
        setUserStats(prev => ({
          ...prev,
          streak: 1,
          lastActiveDate: today
        }))
        setDailyTasks(dailyTasksData) // Сброс ежедневных заданий
        setDailyStats({ topicsToday: 0, quizzesToday: 0, pointsToday: 0, timeToday: 0 }) // Сброс дневной статистики
      } else {
        setUserStats(prev => ({ ...prev, lastActiveDate: today }))
      }
      
      localStorage.setItem('lastActiveDate_v2', today)
    }
  }, [])

  // Клавиатурные сокращения
  useEffect(() => {
    const handleKeyDown = (e: KeyboardEvent) => {
      // Игнорируем если фокус на input
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return
      
      // ? - показать сокращения
      if (e.key === '?') {
        setShowShortcuts(true)
        return
      }
      
      // Escape - закрыть диалоги
      if (e.key === 'Escape') {
        setShowShortcuts(false)
        setTopicDialogOpen(false)
        if (quizDialogOpen) setQuizDialogOpen(false)
        return
      }
      
      // 1-9 - выбор класса
      if (e.key >= '1' && e.key <= '9') {
        const gradeNum = parseInt(e.key)
        if (gradeNum <= 11) {
          setSelectedGrade(gradeNum)
          setVisitedClasses(prev => new Set([...prev, gradeNum]))
        }
        return
      }
      
      // 0 - подготовительный класс
      if (e.key === '0') {
        setSelectedGrade(0)
        setVisitedClasses(prev => new Set([...prev, 0]))
        return
      }
      
      // Tab navigation
      if (e.key === 't' || e.key === 'е') { // T или Е (русская)
        setActiveTab('subjects')
        return
      }
      if (e.key === 'a' || e.key === 'ф') { // A или Ф
        setActiveTab('tasks')
        return
      }
      if (e.key === 'c' || e.key === 'с') { // C или С
        setActiveTab('achievements')
        return
      }
      if (e.key === 's' || e.key === 'ы') { // S или Ы
        setActiveTab('stats')
        return
      }
    }
    
    window.addEventListener('keydown', handleKeyDown)
    return () => window.removeEventListener('keydown', handleKeyDown)
  }, [quizDialogOpen])

  // Таймер обучения
  useEffect(() => {
    let interval: NodeJS.Timeout | null = null
    if (isTimerRunning) {
      interval = setInterval(() => {
        setStudyTime(prev => prev + 1)
      }, 1000)
    }
    return () => {
      if (interval) clearInterval(interval)
    }
  }, [isTimerRunning])

  // Таймер экзамена
  useEffect(() => {
    let interval: NodeJS.Timeout | null = null
    if (examMode) {
      interval = setInterval(() => {
        setExamTimer(prev => prev + 1)
      }, 1000)
    }
    return () => {
      if (interval) clearInterval(interval)
    }
  }, [examMode])

  // Сохранение данных
  useEffect(() => {
    localStorage.setItem('schoolProgress_v2', JSON.stringify(progress))
    localStorage.setItem('schoolStats_v2', JSON.stringify(userStats))
    // Для достижений сохраняем только статус разблокировки (без React иконок)
    const achievementsSaveData = achievements.map(a => ({
      id: a.id,
      unlocked: a.unlocked,
      unlockedAt: a.unlockedAt
    }))
    localStorage.setItem('schoolAchievements_v2', JSON.stringify(achievementsSaveData))
    localStorage.setItem('visitedClasses_v2', JSON.stringify([...visitedClasses]))
    localStorage.setItem('dailyTasks_v2', JSON.stringify(dailyTasks))
    localStorage.setItem('activityLog_v2', JSON.stringify(activityLog))
    localStorage.setItem('dailyStats_v2', JSON.stringify(dailyStats))
    localStorage.setItem('streakFreeze_v2', JSON.stringify(streakFreeze))
    localStorage.setItem('bookmarks_v2', JSON.stringify(bookmarks))
    localStorage.setItem('notes_v2', JSON.stringify(notes))
    localStorage.setItem('studyTime_v2', JSON.stringify(studyTime))
    localStorage.setItem('dailyChallengeDone_v2', JSON.stringify(dailyChallengeDone))
    localStorage.setItem('perfectQuizzesCount_v2', JSON.stringify(perfectQuizzesCount))
    localStorage.setItem('totalChallengesCompleted_v2', JSON.stringify(totalChallengesCompleted))
    localStorage.setItem('currentCombo_v2', JSON.stringify(currentCombo))
    localStorage.setItem('maxCombo_v2', JSON.stringify(maxCombo))
    localStorage.setItem('recentTopics_v2', JSON.stringify(recentTopics))
  }, [progress, userStats, achievements, visitedClasses, dailyTasks, activityLog, dailyStats, streakFreeze, bookmarks, notes, studyTime, dailyChallengeDone, perfectQuizzesCount, totalChallengesCompleted, currentCombo, maxCombo, recentTopics])

  // Подсчёт общего прогресса
  const overallProgress = useMemo(() => {
    let total = 0
    let completed = 0
    schoolData.forEach(grade => {
      grade.subjects.forEach(subject => {
        total += subject.topics.length
        subject.topics.forEach(topic => {
          if (progress[subject.id]?.[topic.id]) completed++
        })
      })
    })
    return total > 0 ? Math.round((completed / total) * 100) : 0
  }, [progress])

  // Подсчёт тем
  const totalTopicsCompleted = useMemo(() => {
    let completed = 0
    schoolData.forEach(grade => {
      grade.subjects.forEach(subject => {
        subject.topics.forEach(topic => {
          if (progress[subject.id]?.[topic.id]) completed++
        })
      })
    })
    return completed
  }, [progress])

  // Определение ранга
  const getCurrentRank = useCallback((level: number) => {
    let currentRank = RANKS[0]
    for (const rank of RANKS) {
      if (level >= rank.minLevel) currentRank = rank
    }
    return currentRank
  }, [])

  // Функция воспроизведения звуков
  const playSound = useCallback((type: 'success' | 'error' | 'achievement' | 'click' | 'levelup') => {
    if (!soundEnabled) return
    
    try {
      const audioContext = new (window.AudioContext || (window as unknown as {webkitAudioContext: typeof AudioContext}).webkitAudioContext)()
      const oscillator = audioContext.createOscillator()
      const gainNode = audioContext.createGain()
      
      oscillator.connect(gainNode)
      gainNode.connect(audioContext.destination)
      
      // Разные звуки для разных событий
      const sounds: Record<string, { frequency: number; duration: number; type: OscillatorType; frequencyEnd?: number }> = {
        success: { frequency: 523.25, duration: 0.15, type: 'sine', frequencyEnd: 659.25 }, // C5 -> E5
        error: { frequency: 200, duration: 0.2, type: 'sawtooth' }, // Низкий звук
        achievement: { frequency: 523.25, duration: 0.3, type: 'sine', frequencyEnd: 783.99 }, // C5 -> G5
        click: { frequency: 800, duration: 0.05, type: 'sine' },
        levelup: { frequency: 392, duration: 0.5, type: 'sine', frequencyEnd: 784 } // G4 -> G5
      }
      
      const sound = sounds[type] || sounds.click
      oscillator.type = sound.type
      oscillator.frequency.setValueAtTime(sound.frequency, audioContext.currentTime)
      if (sound.frequencyEnd) {
        oscillator.frequency.exponentialRampToValueAtTime(sound.frequencyEnd, audioContext.currentTime + sound.duration)
      }
      
      gainNode.gain.setValueAtTime(0.3, audioContext.currentTime)
      gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + sound.duration)
      
      oscillator.start(audioContext.currentTime)
      oscillator.stop(audioContext.currentTime + sound.duration)
    } catch {
      // Игнорируем ошибки аудио
    }
  }, [soundEnabled])

  // Добавление опыта
  const addExperience = useCallback((amount: number) => {
    // Применяем бустер
    const boostedAmount = Math.round(amount * xpBooster)
    
    setUserStats(prev => {
      let newExp = prev.experience + boostedAmount
      let newLevel = prev.level
      let newPoints = prev.totalPoints + boostedAmount
      let leveledUp = false
      
      // Уровни
      while (newExp >= XP_PER_LEVEL) {
        newExp -= XP_PER_LEVEL
        newLevel++
        leveledUp = true
      }
      
      // Звук при повышении уровня
      if (leveledUp) {
        setTimeout(() => playSound('levelup'), 100)
        setShowConfetti(true)
        setTimeout(() => setShowConfetti(false), 4000)
      }
      
      const rank = getCurrentRank(newLevel)
      
      return {
        ...prev,
        experience: newExp,
        level: newLevel,
        totalPoints: newPoints,
        rank: rank.name
      }
    })
  }, [getCurrentRank, playSound, xpBooster])

  // Переключение темы
  const toggleTopic = useCallback((subjectId: string, topic: Topic) => {
    const wasCompleted = progress[subjectId]?.[topic.id]
    
    setProgress(prev => {
      const newProgress = { ...prev }
      if (!newProgress[subjectId]) newProgress[subjectId] = {}
      newProgress[subjectId][topic.id] = !wasCompleted
      return newProgress
    })
    
    if (!wasCompleted) {
      playSound('success')
      const points = topic.difficulty === 'easy' ? 15 : topic.difficulty === 'medium' ? 25 : 40
      addExperience(points)
      
      // Обновление ежедневных заданий
      setDailyTasks(prev => prev.map(task => {
        if (task.type === 'topics' && !task.completed) {
          const newProgress = task.progress + 1
          return {
            ...task,
            progress: newProgress,
            completed: newProgress >= task.target
          }
        }
        if (task.type === 'points' && !task.completed) {
          const newProgress = task.progress + points
          return {
            ...task,
            progress: newProgress,
            completed: newProgress >= task.target
          }
        }
        return task
      }))
      
      // Обновление дневной статистики
      setDailyStats(prev => ({
        ...prev,
        topicsToday: prev.topicsToday + 1,
        pointsToday: prev.pointsToday + points,
        timeToday: prev.timeToday + topic.estimatedTime
      }))
      
      // Добавление в лог активности
      const logItem: ActivityLogItem = {
        id: Date.now().toString(),
        type: 'topic',
        title: topic.title,
        timestamp: new Date().toISOString(),
        points
      }
      setActivityLog(prev => [logItem, ...prev.slice(0, 49)]) // Храним последние 50 записей
    }
    
    setUserStats(prev => ({
      ...prev,
      topicsCompleted: wasCompleted ? prev.topicsCompleted - 1 : prev.topicsCompleted + 1
    }))
  }, [progress, addExperience, playSound])

  // Проверка достижений
  useEffect(() => {
    const newAchievements = [...achievements]
    let changed = false
    
    const updateAchievement = (id: string, condition: boolean) => {
      const idx = newAchievements.findIndex(a => a.id === id)
      if (idx !== -1 && !newAchievements[idx].unlocked && condition) {
        newAchievements[idx].unlocked = true
        newAchievements[idx].unlockedAt = new Date().toISOString()
        changed = true
        addExperience(newAchievements[idx].points)
        playSound('achievement')
        setShowConfetti(true)
        setTimeout(() => setShowConfetti(false), 3000)
      }
    }
    
    // Обычные достижения
    updateAchievement('first_step', totalTopicsCompleted >= 1)
    updateAchievement('explorer', totalTopicsCompleted >= 10)
    updateAchievement('quiz_master', userStats.quizzesCompleted >= 5)
    updateAchievement('streak_3', userStats.streak >= 3)
    updateAchievement('bookmark_first', bookmarks.length >= 1)
    updateAchievement('note_taker', Object.keys(notes).filter(id => notes[id]?.trim()).length >= 1)
    updateAchievement('challenge_first', totalChallengesCompleted >= 1)
    
    // Редкие достижения
    updateAchievement('scholar', totalTopicsCompleted >= 50)
    updateAchievement('expert', totalTopicsCompleted >= 100)
    updateAchievement('streak_7', userStats.streak >= 7)
    updateAchievement('streak_14', userStats.streak >= 14)
    updateAchievement('quiz_pro', userStats.quizzesCompleted >= 20)
    updateAchievement('bookmark_collector', bookmarks.length >= 10)
    
    // Эпические достижения
    updateAchievement('all_classes', visitedClasses.size >= 12)
    updateAchievement('streak_30', userStats.streak >= 30)
    updateAchievement('knowledge_seeker', totalTopicsCompleted >= 200)
    updateAchievement('perfect_ten', perfectQuizzesCount >= 10)
    updateAchievement('challenge_master', totalChallengesCompleted >= 30)
    
    // Легендарные достижения
    updateAchievement('streak_100', userStats.streak >= 100)
    updateAchievement('perfectionist', perfectQuizzesCount >= 50)
    updateAchievement('grandmaster', userStats.level >= 100)
    
    if (changed) setAchievements(newAchievements)
  }, [totalTopicsCompleted, userStats.quizzesCompleted, userStats.streak, userStats.level, visitedClasses.size, achievements, addExperience, playSound, bookmarks.length, notes, perfectQuizzesCount, totalChallengesCompleted])

  // Прогресс по предмету
  const getSubjectProgress = useCallback((subject: Subject) => {
    // Получаем все уроки из sections
    const allLessons = subject.sections.flatMap(s => s.topics.flatMap(t => t.lessons))
    if (allLessons.length === 0) return 0
    
    const completed = allLessons.filter(l => progress[subject.id]?.[l.id]).length
    return Math.round((completed / allLessons.length) * 100)
  }, [progress])

  // Начать квиз
  const startQuiz = useCallback((subject: Subject) => {
    if (subject.quiz && subject.quiz.length > 0) {
      setCurrentQuiz(subject.quiz)
      setCurrentQuizSubject(subject.title)
      setCurrentQuestionIndex(0)
      setSelectedAnswer(null)
      setShowResult(false)
      setQuizScore(0)
      setQuizDialogOpen(true)
    }
  }, [])

  // Ответить на вопрос
  const answerQuestion = useCallback((answerIndex: number) => {
    if (showResult) return
    setSelectedAnswer(answerIndex)
    setShowResult(true)
    
    if (answerIndex === currentQuiz[currentQuestionIndex].correctAnswer) {
      setQuizScore(s => s + 1)
      playSound('success')
      // Увеличиваем комбо
      setCurrentCombo(prev => {
        const newCombo = prev + 1
        setMaxCombo(max => Math.max(max, newCombo))
        // Бонус за комбо
        if (newCombo > 0 && newCombo % 5 === 0) {
          addExperience(newCombo * 2) // Бонусные XP за серию
        }
        return newCombo
      })
    } else {
      playSound('error')
      // Сбрасываем комбо при ошибке
      setCurrentCombo(0)
    }
  }, [showResult, currentQuiz, currentQuestionIndex, playSound, addExperience])

  // Следующий вопрос
  const nextQuestion = useCallback(() => {
    if (currentQuestionIndex < currentQuiz.length - 1) {
      setCurrentQuestionIndex(i => i + 1)
      setSelectedAnswer(null)
      setShowResult(false)
    } else {
      const finalScore = quizScore + (selectedAnswer === currentQuiz[currentQuestionIndex].correctAnswer ? 1 : 0)
      const isPerfect = finalScore === currentQuiz.length
      
      if (isPerfect) {
        // Увеличиваем счётчик идеальных квизов
        setPerfectQuizzesCount(prev => prev + 1)
        playSound('achievement')
      }
      
      // Начисление очков
      const totalPoints = currentQuiz.reduce((sum, q) => sum + q.points, 0)
      const earnedPoints = currentQuiz.slice(0, currentQuestionIndex + 1).reduce((sum, q, i) => {
        // Простая логика: за правильные ответы
        return sum + (i < currentQuestionIndex && i < quizScore ? q.points : 0)
      }, 0) + (selectedAnswer === currentQuiz[currentQuestionIndex].correctAnswer ? currentQuiz[currentQuestionIndex].points : 0)
      
      addExperience(earnedPoints)
      
      setUserStats(prev => ({
        ...prev,
        quizzesCompleted: prev.quizzesCompleted + 1
      }))
      
      // Обновление ежедневных заданий
      setDailyTasks(prev => prev.map(task => {
        if (task.type === 'quizzes' && !task.completed) {
          return { ...task, progress: task.progress + 1, completed: true }
        }
        if (task.type === 'points' && !task.completed) {
          const newProgress = task.progress + earnedPoints
          return { ...task, progress: newProgress, completed: newProgress >= task.target }
        }
        return task
      }))
      
      setQuizDialogOpen(false)
      setShowConfetti(true)
      setTimeout(() => setShowConfetti(false), 3000)
    }
  }, [currentQuestionIndex, currentQuiz, selectedAnswer, quizScore, achievements, addExperience])

  // Выбор класса
  const selectGrade = useCallback((gradeId: number) => {
    setSelectedGrade(gradeId)
    setVisitedClasses(prev => new Set([...prev, gradeId]))
    setExpandedSubject(null)
  }, [])

  // ==================== ФУНКЦИИ ДЛЯ РЕЖИМА КАРТОЧЕК ====================
  const startFlashcardMode = useCallback(() => {
    const grade = schoolData.find(g => g.id === selectedGrade)
    if (!grade) return
    
    const allFlashcards: {question: string, answer: string, subject: string}[] = []
    grade.subjects.forEach(subject => {
      if (subject.quiz) {
        subject.quiz.forEach(q => {
          allFlashcards.push({
            question: q.question,
            answer: q.options[q.correctAnswer],
            subject: subject.title
          })
        })
      }
    })
    
    if (allFlashcards.length > 0) {
      // Перемешиваем карточки
      const shuffled = allFlashcards.sort(() => Math.random() - 0.5)
      setFlashcards(shuffled)
      setCurrentFlashcardIndex(0)
      setIsFlipped(false)
      setFlashcardStats({known: 0, unknown: 0})
      setFlashcardMode(true)
    }
  }, [selectedGrade])

  const handleFlashcardKnown = useCallback(() => {
    setFlashcardStats(prev => ({...prev, known: prev.known + 1}))
    if (currentFlashcardIndex < flashcards.length - 1) {
      setCurrentFlashcardIndex(prev => prev + 1)
      setIsFlipped(false)
    } else {
      // Завершение режима карточек
      addExperience(flashcardStats.known * 5 + 10)
      setFlashcardMode(false)
    }
  }, [currentFlashcardIndex, flashcards.length, flashcardStats.known, addExperience])

  const handleFlashcardUnknown = useCallback(() => {
    setFlashcardStats(prev => ({...prev, unknown: prev.unknown + 1}))
    if (currentFlashcardIndex < flashcards.length - 1) {
      setCurrentFlashcardIndex(prev => prev + 1)
      setIsFlipped(false)
    } else {
      // Завершение режима карточек
      addExperience(flashcardStats.known * 5 + 10)
      setFlashcardMode(false)
    }
  }, [currentFlashcardIndex, flashcards.length, flashcardStats.known, addExperience])

  // ==================== ФУНКЦИИ ДЛЯ РЕЖИМА ЭКЗАМЕНА ====================
  const startExamMode = useCallback((gradeId: number, subjectId?: string) => {
    const grade = schoolData.find(g => g.id === gradeId)
    if (!grade) return
    
    let questions: QuizQuestion[] = []
    if (subjectId && subjectId !== 'all') {
      const subject = grade.subjects.find(s => s.id === subjectId)
      if (subject && subject.quiz) {
        questions = [...subject.quiz]
      }
    } else {
      // Все предметы
      grade.subjects.forEach(subject => {
        if (subject.quiz) {
          questions.push(...subject.quiz)
        }
      })
    }
    
    if (questions.length > 0) {
      const shuffled = questions.sort(() => Math.random() - 0.5)
      setExamQuestions(shuffled.slice(0, Math.min(20, shuffled.length)))
      setExamAnswers([])
      setExamTimer(0)
      setExamSubject(subjectId || 'all')
      setExamGrade(gradeId)
      setExamMode(true)
    }
  }, [])

  const handleExamAnswer = useCallback((answerIndex: number) => {
    const currentQuestion = examQuestions[examAnswers.length]
    const isCorrect = answerIndex === currentQuestion?.correctAnswer
    
    setExamAnswers(prev => [...prev, answerIndex])
    if (isCorrect) {
      setExamCorrectAnswers(prev => [...prev, examAnswers.length])
      playSound('success')
    } else {
      playSound('error')
    }
    
    // Автоматически переходим к следующему вопросу или завершаем
    if (examAnswers.length + 1 >= examQuestions.length) {
      setTimeout(() => setShowExamResults(true), 500)
    }
  }, [examAnswers.length, examQuestions, playSound])

  const finishExam = useCallback(() => {
    const correct = examCorrectAnswers.length
    const totalPoints = correct * 15
    addExperience(totalPoints)
    
    setUserStats(prev => ({
      ...prev,
      quizzesCompleted: prev.quizzesCompleted + 1
    }))
    
    setDailyStats(prev => ({
      ...prev,
      quizzesToday: prev.quizzesToday + 1,
      pointsToday: prev.pointsToday + totalPoints
    }))
    
    setShowConfetti(true)
    setTimeout(() => setShowConfetti(false), 3000)
    
    // Сбрасываем состояние экзамена
    setExamMode(false)
    setShowExamResults(false)
    setExamAnswers([])
    setExamCorrectAnswers([])
    setExamTimer(0)
    setExamGrade(null)
    setExamSubject('all')
  }, [examCorrectAnswers.length, addExperience])

  // ==================== ФУНКЦИИ ДЛЯ ЕЖЕДНЕВНОГО ЧЕЛЛЕНДЖА ====================
  const startDailyChallenge = useCallback(() => {
    // Собираем вопросы из всех классов
    const allQuestions: QuizQuestion[] = []
    schoolData.forEach(grade => {
      grade.subjects.forEach(subject => {
        if (subject.quiz) {
          allQuestions.push(...subject.quiz)
        }
      })
    })
    
    if (allQuestions.length > 0) {
      // Сортируем по дате для ежедневного челленджа
      const today = new Date().toDateString()
      const seed = today.split('').reduce((a, b) => a + b.charCodeAt(0), 0)
      const shuffled = allQuestions.sort(() => ((seed % 100) / 100) - 0.5)
      setChallengeQuestions(shuffled.slice(0, 10))
      setChallengeIndex(0)
      setChallengeScore(0)
      setChallengeCompleted(false)
      setChallengeMode(true)
    }
  }, [])

  const handleChallengeAnswer = useCallback((answerIndex: number) => {
    const isCorrect = answerIndex === challengeQuestions[challengeIndex]?.correctAnswer
    if (isCorrect) {
      setChallengeScore(prev => prev + 1)
      playSound('success')
    } else {
      playSound('error')
    }
    
    if (challengeIndex < challengeQuestions.length - 1) {
      setChallengeIndex(prev => prev + 1)
    } else {
      // Завершение челленджа
      const bonusXP = challengeScore * 10 + (isCorrect ? 10 : 0) + 50
      addExperience(bonusXP)
      playSound('achievement')
      setDailyChallengeDone(true)
      setChallengeCompleted(true)
      setTotalChallengesCompleted(prev => prev + 1)
      
      // Обновление ежедневных заданий
      setDailyTasks(prev => prev.map(task => {
        if (task.type === 'challenges' && !task.completed) {
          return { ...task, progress: task.progress + 1, completed: true }
        }
        return task
      }))
      
      setDailyStats(prev => ({
        ...prev,
        quizzesToday: prev.quizzesToday + 1,
        pointsToday: prev.pointsToday + bonusXP
      }))
      
      setShowConfetti(true)
      setTimeout(() => setShowConfetti(false), 3000)
    }
  }, [challengeIndex, challengeQuestions, challengeScore, addExperience, playSound])

  // Фильтрация предметов
  const filteredSubjects = useMemo(() => {
    const grade = schoolData.find(g => g.id === selectedGrade)
    if (!grade) return []
    
    if (!searchQuery) return grade.subjects
    
    return grade.subjects.filter(subject => 
      subject.title.toLowerCase().includes(searchQuery.toLowerCase()) ||
      subject.sections.some(s => 
        s.topics.some(t => 
          t.title.toLowerCase().includes(searchQuery.toLowerCase()) ||
          t.lessons.some(l => l.title.toLowerCase().includes(searchQuery.toLowerCase()))
        )
      )
    )
  }, [selectedGrade, searchQuery])

  const currentGrade = schoolData.find(g => g.id === selectedGrade)
  const currentRank = getCurrentRank(userStats.level)

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 relative overflow-hidden">
      {/* Конфетти */}
      {showConfetti && (
        <div className="fixed inset-0 pointer-events-none z-50">
          {Array.from({ length: 50 }).map((_, i) => (
            <div
              key={i}
              className="absolute animate-fall"
              style={{
                left: `${Math.random() * 100}%`,
                top: `-20px`,
                animationDelay: `${Math.random() * 2}s`,
                animationDuration: `${2 + Math.random() * 3}s`
              }}
            >
              <span className="text-2xl">
                {['🎉', '⭐', '🏆', '✨', '🌟', '💫', '🎊'][Math.floor(Math.random() * 7)]}
              </span>
            </div>
          ))}
        </div>
      )}

      {/* Шапка */}
      <header className="sticky top-0 z-40 backdrop-blur-xl bg-slate-900/80 border-b border-white/10">
        <div className="max-w-7xl mx-auto px-4 py-3">
          <div className="flex items-center justify-between gap-4 flex-wrap">
            <div className="flex items-center gap-3">
              <div className="p-2 rounded-xl bg-gradient-to-br from-purple-500 to-blue-500 shadow-lg shadow-purple-500/30">
                <GraduationCap className="w-7 h-7 text-white" />
              </div>
              <div>
                <h1 className="text-xl font-bold text-white">ИНЕТШКОЛА</h1>
                <div className="flex items-center gap-2 text-sm text-purple-300">
                  <span className="flex items-center gap-1 px-2 py-0.5 rounded-full bg-gradient-to-r from-gray-500/20 to-gray-600/20 border border-white/10">
                    <span className="text-base">{currentRank.icon}</span>
                    <span className="font-medium">{currentRank.name}</span>
                  </span>
                  <span className="text-white/30">•</span>
                  <span>Уровень {userStats.level}</span>
                </div>
              </div>
            </div>
            
            <div className="flex items-center gap-3">
              {/* Стрик с заморозками */}
              <div className="flex items-center gap-2 px-3 py-1.5 rounded-xl bg-gradient-to-r from-orange-500/20 to-red-500/20 border border-orange-500/30">
                <Flame className="w-4 h-4 text-orange-400" />
                <span className="font-bold text-orange-400">{userStats.streak}</span>
                {streakFreeze > 0 && (
                  <span title="Заморозки стрика" className="text-xs text-cyan-400 ml-1">❄️{streakFreeze}</span>
                )}
              </div>
              
              {/* Уровень и прогресс ранга */}
              <div className="hidden sm:flex flex-col gap-1">
                <div className="flex items-center gap-2">
                  <div className="w-32 h-2 bg-white/10 rounded-full overflow-hidden">
                    <div 
                      className="h-full bg-gradient-to-r from-purple-500 to-blue-500 transition-all duration-300"
                      style={{ width: `${(userStats.experience / XP_PER_LEVEL) * 100}%` }}
                    />
                  </div>
                  <span className="text-xs text-gray-400">{userStats.experience}/{XP_PER_LEVEL} XP</span>
                </div>
                <div className="flex items-center gap-2">
                  <div className="w-32 h-1.5 bg-white/5 rounded-full overflow-hidden">
                    <div 
                      className="h-full bg-gradient-to-r from-gray-500 to-gray-600 transition-all duration-300"
                      style={{ width: `${(userStats.level / (RANKS[RANKS.findIndex(r => r.name === currentRank.name) + 1]?.minLevel || userStats.level + 10)) * 100}%` }}
                    />
                  </div>
                  <span className="text-xs text-gray-500">{currentRank.icon}→{RANKS[Math.min(RANKS.findIndex(r => r.name === currentRank.name) + 1, RANKS.length - 1)]?.icon}</span>
                </div>
              </div>
              
              {/* Очки */}
              <div className="flex items-center gap-2 px-3 py-1.5 rounded-xl bg-gradient-to-r from-amber-500/20 to-yellow-500/20 border border-amber-500/30">
                <Star className="w-4 h-4 text-yellow-400" />
                <span className="font-bold text-yellow-400">{userStats.totalPoints}</span>
              </div>
              
              {/* Звук */}
              <Button
                variant="ghost"
                size="icon"
                onClick={() => setSoundEnabled(!soundEnabled)}
                className="hidden sm:flex h-9 w-9 text-cyan-400 hover:text-white hover:bg-white/10"
                title={soundEnabled ? "Выключить звук" : "Включить звук"}
              >
                {soundEnabled ? <Volume2 className="w-5 h-5" /> : <VolumeX className="w-5 h-5" />}
              </Button>
              
              {/* Настройки */}
              <Button
                variant="ghost"
                size="icon"
                onClick={() => setShowSettings(true)}
                className="hidden sm:flex h-9 w-9 text-gray-400 hover:text-white hover:bg-white/10"
                title="Настройки"
              >
                <Settings className="w-5 h-5" />
              </Button>
              
              {/* Поиск */}
              <div className="relative hidden md:block">
                <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" />
                <Input
                  placeholder="Поиск..."
                  value={searchQuery}
                  onChange={(e) => setSearchQuery(e.target.value)}
                  className="pl-9 w-48 h-9 bg-white/10 border-white/20 text-white placeholder:text-gray-400 text-sm"
                />
              </div>
              
              {/* Клавиатурные сокращения */}
              <Button
                variant="ghost"
                size="icon"
                onClick={() => setShowShortcuts(true)}
                className="hidden sm:flex h-9 w-9 text-gray-400 hover:text-white hover:bg-white/10"
              >
                <Keyboard className="w-4 h-4" />
              </Button>
            </div>
          </div>
        </div>
      </header>

      {/* Прогресс */}
      <div className="max-w-7xl mx-auto px-4 py-3">
        {/* Тематический день недели */}
        {(() => {
          const dayOfWeek = new Date().getDay()
          const themeDays: Record<number, { name: string; subject: string; icon: React.ReactNode; color: string }> = {
            1: { name: 'Математический понедельник', subject: 'Математика', icon: <Calculator className="w-4 h-4" />, color: 'from-blue-500/20 to-cyan-500/20 border-blue-500/30' },
            2: { name: 'Гуманитарный вторник', subject: 'Русский язык', icon: <Book className="w-4 h-4" />, color: 'from-red-500/20 to-orange-500/20 border-red-500/30' },
            3: { name: 'Научная среда', subject: 'Окружающий мир', icon: <FlaskConical className="w-4 h-4" />, color: 'from-green-500/20 to-emerald-500/20 border-green-500/30' },
            4: { name: 'Исторический четверг', subject: 'История', icon: <Map className="w-4 h-4" />, color: 'from-amber-500/20 to-yellow-500/20 border-amber-500/30' },
            5: { name: 'Лингвистическая пятница', subject: 'Иностранный язык', icon: <Languages className="w-4 h-4" />, color: 'from-purple-500/20 to-pink-500/20 border-purple-500/30' },
            6: { name: 'Творческая суббота', subject: 'ИЗО', icon: <Palette className="w-4 h-4" />, color: 'from-pink-500/20 to-rose-500/20 border-pink-500/30' },
            0: { name: 'День отдыха', subject: 'Любой предмет', icon: <Sun className="w-4 h-4" />, color: 'from-cyan-500/20 to-blue-500/20 border-cyan-500/30' }
          }
          const today = themeDays[dayOfWeek]
          
          return (
            <Card className={`bg-gradient-to-r ${today.color} mb-3`}>
              <CardContent className="p-3">
                <div className="flex items-center justify-between">
                  <div className="flex items-center gap-3">
                    <div className="p-2 rounded-lg bg-white/10">
                      {today.icon}
                    </div>
                    <div>
                      <p className="text-white font-medium">{today.name}</p>
                      <p className="text-xs text-gray-400">Рекомендуемый предмет: {today.subject}</p>
                    </div>
                  </div>
                  <Badge className="bg-white/10 text-white border-white/20">
                    x1.5 XP
                  </Badge>
                </div>
              </CardContent>
            </Card>
          )
        })()}

        {/* Комбо-бонус */}
        {currentCombo >= 3 && (
          <Card className="bg-gradient-to-r from-amber-500/20 to-orange-500/20 border-amber-500/30 mb-3 animate-pulse">
            <CardContent className="p-3">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-3">
                  <Flame className="w-6 h-6 text-amber-400" />
                  <div>
                    <p className="text-amber-300 font-bold">Комбо x{currentCombo}!</p>
                    <p className="text-xs text-gray-400">Серия правильных ответов</p>
                  </div>
                </div>
                <div className="text-right">
                  <p className="text-amber-400 font-bold">+{currentCombo * 2} XP</p>
                  <p className="text-xs text-gray-400">бонус за каждые 5</p>
                </div>
              </div>
            </CardContent>
          </Card>
        )}

        <Card className="bg-white/5 border-white/10 backdrop-blur overflow-hidden">
          <CardContent className="p-4">
            <div className="flex items-center justify-between mb-2 flex-wrap gap-2">
              <div className="flex items-center gap-2">
                <TrendingUp className="w-5 h-5 text-green-400" />
                <span className="text-white font-medium">Общий прогресс</span>
              </div>
              <div className="flex items-center gap-4 text-sm flex-wrap">
                {/* Таймер обучения */}
                <div className="flex items-center gap-2 px-3 py-1 rounded-lg bg-white/5 border border-white/10">
                  <Timer className="w-4 h-4 text-cyan-400" />
                  <span className="font-mono text-cyan-400">
                    {Math.floor(studyTime / 3600).toString().padStart(2, '0')}:
                    {Math.floor((studyTime % 3600) / 60).toString().padStart(2, '0')}:
                    {(studyTime % 60).toString().padStart(2, '0')}
                  </span>
                  <Button
                    variant="ghost"
                    size="icon"
                    onClick={() => setIsTimerRunning(!isTimerRunning)}
                    className="h-6 w-6 p-0"
                  >
                    {isTimerRunning ? (
                      <Pause className="w-3 h-3 text-white" />
                    ) : (
                      <Play className="w-3 h-3 text-white" />
                    )}
                  </Button>
                </div>
                <span className="text-gray-400">{totalTopicsCompleted} тем</span>
                <span className="text-green-400 font-bold">{overallProgress}%</span>
              </div>
            </div>
            <Progress value={overallProgress} className="h-2" />
            
            {/* Экспорт/Импорт */}
            <div className="flex gap-2 mt-3 pt-3 border-t border-white/10">
              <Button
                variant="outline"
                size="sm"
                onClick={() => {
                  const data = {
                    progress,
                    userStats,
                    achievements,
                    visitedClasses: [...visitedClasses],
                    dailyTasks,
                    activityLog,
                    dailyStats,
                    streakFreeze,
                    bookmarks,
                    notes,
                    studyTime,
                    exportDate: new Date().toISOString()
                  }
                  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' })
                  const url = URL.createObjectURL(blob)
                  const a = document.createElement('a')
                  a.href = url
                  a.download = `inetshkola-progress-${new Date().toISOString().split('T')[0]}.json`
                  a.click()
                  URL.revokeObjectURL(url)
                }}
                className="bg-white/5 border-white/20 text-gray-300 hover:bg-white/10 h-7 text-xs"
              >
                <Download className="w-3 h-3 mr-1" />
                Экспорт
              </Button>
              <label className="cursor-pointer">
                <Button
                  variant="outline"
                  size="sm"
                  asChild
                  className="bg-white/5 border-white/20 text-gray-300 hover:bg-white/10 h-7 text-xs"
                >
                  <span>
                    <Upload className="w-3 h-3 mr-1" />
                    Импорт
                  </span>
                </Button>
                <input
                  type="file"
                  accept=".json"
                  className="hidden"
                  onChange={(e) => {
                    const file = e.target.files?.[0]
                    if (file) {
                      const reader = new FileReader()
                      reader.onload = (event) => {
                        try {
                          const data = JSON.parse(event.target?.result as string)
                          if (data.progress) setProgress(data.progress)
                          if (data.userStats) setUserStats(data.userStats)
                          if (data.achievements) setAchievements(data.achievements)
                          if (data.visitedClasses) setVisitedClasses(new Set(data.visitedClasses))
                          if (data.dailyTasks) setDailyTasks(data.dailyTasks)
                          if (data.activityLog) setActivityLog(data.activityLog)
                          if (data.dailyStats) setDailyStats(data.dailyStats)
                          if (data.streakFreeze) setStreakFreeze(data.streakFreeze)
                          if (data.bookmarks) setBookmarks(data.bookmarks)
                          if (data.notes) setNotes(data.notes)
                          if (data.studyTime) setStudyTime(data.studyTime)
                          alert('Прогресс успешно импортирован!')
                        } catch {
                          alert('Ошибка при импорте файла')
                        }
                      }
                      reader.readAsText(file)
                    }
                  }}
                />
              </label>
            </div>
          </CardContent>
        </Card>
      </div>

      {/* Цитата дня */}
      <div className="max-w-7xl mx-auto px-4 pb-3">
        <Card className="bg-gradient-to-r from-purple-500/10 via-blue-500/10 to-cyan-500/10 border-white/10">
          <CardContent className="p-4">
            <div className="flex items-center gap-3">
              <Sparkles className="w-5 h-5 text-yellow-400 shrink-0" />
              <div>
                <p className="text-white/90 text-sm italic">
                  "{QUOTES[Math.floor(new Date().getDate() % QUOTES.length)].text}"
                </p>
                <p className="text-gray-400 text-xs mt-1">— {QUOTES[Math.floor(new Date().getDate() % QUOTES.length)].author}</p>
              </div>
            </div>
          </CardContent>
        </Card>
      </div>

      {/* Ежедневная статистика */}
      {(dailyStats.topicsToday > 0 || dailyStats.quizzesToday > 0 || dailyStats.pointsToday > 0) && (
        <div className="max-w-7xl mx-auto px-4 pb-3">
          <Card className="bg-gradient-to-r from-purple-500/10 to-blue-500/10 border-purple-500/20 backdrop-blur">
            <CardContent className="p-3">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <Calendar className="w-4 h-4 text-purple-400" />
                  <span className="text-sm text-purple-300">Сегодня:</span>
                </div>
                <div className="flex items-center gap-4 text-sm">
                  <div className="flex items-center gap-1">
                    <Book className="w-3.5 h-3.5 text-green-400" />
                    <span className="text-green-400">{dailyStats.topicsToday} тем</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <Zap className="w-3.5 h-3.5 text-yellow-400" />
                    <span className="text-yellow-400">{dailyStats.quizzesToday} тестов</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <Star className="w-3.5 h-3.5 text-amber-400" />
                    <span className="text-amber-400">+{dailyStats.pointsToday} XP</span>
                  </div>
                  {dailyStats.timeToday > 0 && (
                    <div className="flex items-center gap-1">
                      <Clock className="w-3.5 h-3.5 text-blue-400" />
                      <span className="text-blue-400">{dailyStats.timeToday} мин</span>
                    </div>
                  )}
                </div>
              </div>
            </CardContent>
          </Card>
        </div>
      )}

      {/* Кнопки классов */}
      <div className="max-w-7xl mx-auto px-4 pb-3">
        <ScrollArea className="w-full">
          <div className="flex gap-2 pb-2">
            {schoolData.map(grade => (
              <Button
                key={grade.id}
                onClick={() => selectGrade(grade.id)}
                variant={selectedGrade === grade.id ? "default" : "outline"}
                className={`shrink-0 h-9 ${
                  selectedGrade === grade.id
                    ? 'bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 text-white'
                    : 'bg-white/5 border-white/20 text-gray-300 hover:bg-white/10 hover:text-white'
                }`}
              >
                {grade.shortName}
              </Button>
            ))}
          </div>
        </ScrollArea>
      </div>

      {/* Основной контент */}
      <div className="max-w-7xl mx-auto px-4 pb-8">
        <Tabs value={activeTab} onValueChange={setActiveTab} className="w-full">
          <TabsList className="bg-white/5 border border-white/10 mb-4 h-10 flex-wrap">
            <TabsTrigger value="subjects" className="data-[state=active]:bg-purple-600 h-8 text-sm">
              <Book className="w-4 h-4 mr-1.5" />
              Предметы
            </TabsTrigger>
            <TabsTrigger value="flashcards" className="data-[state=active]:bg-purple-600 h-8 text-sm">
              <Brain className="w-4 h-4 mr-1.5" />
              Карточки
            </TabsTrigger>
            <TabsTrigger value="exam" className="data-[state=active]:bg-purple-600 h-8 text-sm">
              <FileText className="w-4 h-4 mr-1.5" />
              Экзамен
            </TabsTrigger>
            <TabsTrigger value="challenge" className="data-[state=active]:bg-purple-600 h-8 text-sm">
              <Zap className="w-4 h-4 mr-1.5" />
              Челлендж
            </TabsTrigger>
            <TabsTrigger value="tasks" className="data-[state=active]:bg-purple-600 h-8 text-sm">
              <Calendar className="w-4 h-4 mr-1.5" />
              Задания
              {dailyTasks.some(t => t.completed) && (
                <Badge className="ml-1.5 h-5 px-1.5 bg-green-500/20 text-green-300 text-xs">
                  {dailyTasks.filter(t => t.completed).length}/{dailyTasks.length}
                </Badge>
              )}
            </TabsTrigger>
            <TabsTrigger value="achievements" className="data-[state=active]:bg-purple-600 h-8 text-sm">
              <Trophy className="w-4 h-4 mr-1.5" />
              Достижения
              {achievements.filter(a => a.unlocked).length > 0 && (
                <Badge className="ml-1.5 h-5 px-1.5 bg-green-500/20 text-green-300 text-xs">
                  {achievements.filter(a => a.unlocked).length}/{achievements.length}
                </Badge>
              )}
            </TabsTrigger>
            <TabsTrigger value="bookmarks" className="data-[state=active]:bg-purple-600 h-8 text-sm">
              <Bookmark className="w-4 h-4 mr-1.5" />
              Избранное
              {bookmarks.length > 0 && (
                <Badge className="ml-1.5 h-5 px-1.5 bg-amber-500/20 text-amber-300 text-xs">
                  {bookmarks.length}
                </Badge>
              )}
            </TabsTrigger>
            <TabsTrigger value="stats" className="data-[state=active]:bg-purple-600 h-8 text-sm">
              <BarChart3 className="w-4 h-4 mr-1.5" />
              Статистика
              {Object.keys(notes).filter(id => notes[id]?.trim()).length > 0 && (
                <Badge className="ml-1.5 h-5 px-1.5 bg-cyan-500/20 text-cyan-300 text-xs">
                  <Pencil className="w-3 h-3" />
                </Badge>
              )}
            </TabsTrigger>
          </TabsList>

          {/* Таб предметов */}
          <TabsContent value="subjects" className="space-y-4">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              {filteredSubjects.map(subject => {
                const subjectProgress = getSubjectProgress(subject)
                const isExpanded = expandedSubject === subject.id
                
                return (
                  <Card 
                    key={subject.id}
                    className={`bg-gradient-to-br ${subject.gradient} bg-opacity-10 border-white/10 backdrop-blur overflow-hidden transition-all duration-300 ${
                      isExpanded ? 'md:col-span-2' : ''
                    }`}
                  >
                    <CardHeader className="pb-2 cursor-pointer" onClick={() => setExpandedSubject(isExpanded ? null : subject.id)}>
                      <div className="flex items-center justify-between">
                        <div className="flex items-center gap-3">
                          <div className={`p-2 rounded-lg bg-white/10 ${subject.color}`}>
                            {subject.icon}
                          </div>
                          <div>
                            <CardTitle className="text-white text-lg">{subject.title}</CardTitle>
                            <CardDescription className="text-white/60">
                              {subject.description}
                            </CardDescription>
                          </div>
                        </div>
                        <div className="flex items-center gap-2">
                          {subject.quiz && subject.quiz.length > 0 && (
                            <Button
                              size="sm"
                              onClick={(e) => { e.stopPropagation(); startQuiz(subject); }}
                              className="bg-white/20 hover:bg-white/30 text-white h-8"
                            >
                              <Zap className="w-4 h-4 mr-1" />
                              Тест
                            </Button>
                          )}
                          <div className="text-right">
                            <div className="text-white/60 text-sm">{subjectProgress}%</div>
                            <ChevronRight className={`w-4 h-4 text-white/40 transition-transform ${isExpanded ? 'rotate-90' : ''}`} />
                          </div>
                        </div>
                      </div>
                    </CardHeader>
                    <CardContent>
                      <Progress value={subjectProgress} className="h-1.5 mb-3" />
                      
                      {isExpanded && (
                        <div className="space-y-3 mt-4">
                          <Separator className="bg-white/10" />
                          {/* Иерархическое отображение: Раздел → Тема → Урок */}
                          <Accordion type="multiple" className="w-full space-y-2">
                            {subject.sections.map(section => {
                              // Считаем прогресс раздела
                              const sectionLessons = section.topics.flatMap(t => t.lessons)
                              const sectionCompleted = sectionLessons.filter(l => progress[subject.id]?.[l.id]).length
                              const sectionTotal = sectionLessons.length
                              const sectionPercent = sectionTotal > 0 ? Math.round((sectionCompleted / sectionTotal) * 100) : 0
                              
                              return (
                                <AccordionItem 
                                  key={section.id} 
                                  value={section.id}
                                  className="border border-white/10 rounded-lg bg-white/5 overflow-hidden"
                                >
                                  <AccordionTrigger className="px-4 py-3 hover:no-underline hover:bg-white/5">
                                    <div className="flex items-center gap-3 w-full">
                                      <div className="p-1.5 rounded-lg bg-white/10">
                                        <Layers className="w-4 h-4 text-purple-300" />
                                      </div>
                                      <div className="flex-1 text-left">
                                        <div className="flex items-center gap-2">
                                          <span className="text-white font-medium">{section.title}</span>
                                          <Badge className="text-xs bg-purple-500/20 text-purple-300">
                                            {section.topics.length} тем
                                          </Badge>
                                        </div>
                                        <p className="text-xs text-gray-400 truncate">{section.description}</p>
                                      </div>
                                      <div className="flex items-center gap-2 mr-2">
                                        <Progress value={sectionPercent} className="w-16 h-1.5" />
                                        <span className="text-xs text-gray-400">{sectionCompleted}/{sectionTotal}</span>
                                      </div>
                                    </div>
                                  </AccordionTrigger>
                                  <AccordionContent className="px-2 pb-2">
                                    {/* Темы внутри раздела */}
                                    <Accordion type="multiple" className="w-full space-y-1.5">
                                      {section.topics.map(topic => {
                                        const topicLessons = topic.lessons
                                        const topicCompleted = topicLessons.filter(l => progress[subject.id]?.[l.id]).length
                                        const topicTotal = topicLessons.length
                                        const topicPercent = topicTotal > 0 ? Math.round((topicCompleted / topicTotal) * 100) : 0
                                        
                                        return (
                                          <AccordionItem 
                                            key={topic.id} 
                                            value={topic.id}
                                            className="border border-white/5 rounded-lg bg-white/5 overflow-hidden"
                                          >
                                            <AccordionTrigger className="px-3 py-2 hover:no-underline hover:bg-white/5">
                                              <div className="flex items-center gap-2 w-full">
                                                <div className="p-1 rounded bg-white/10">
                                                  <Book className="w-3.5 h-3.5 text-blue-300" />
                                                </div>
                                                <div className="flex-1 text-left">
                                                  <span className="text-white text-sm">{topic.title}</span>
                                                  <p className="text-xs text-gray-500 truncate">{topic.description}</p>
                                                </div>
                                                <div className="flex items-center gap-2 mr-2">
                                                  <Progress value={topicPercent} className="w-12 h-1" />
                                                  <span className="text-xs text-gray-500">{topicCompleted}/{topicTotal}</span>
                                                </div>
                                              </div>
                                            </AccordionTrigger>
                                            <AccordionContent className="px-1 pb-1">
                                              {/* Уроки внутри темы */}
                                              <div className="space-y-1">
                                                {topic.lessons.map(lesson => (
                                                  <div
                                                    key={lesson.id}
                                                    className={`flex items-center gap-2 p-2 rounded-lg cursor-pointer transition-all ${
                                                      progress[subject.id]?.[lesson.id]
                                                        ? 'bg-green-500/10 border border-green-500/20'
                                                        : 'bg-white/5 hover:bg-white/10 border border-transparent'
                                                    }`}
                                                    onClick={() => {
                                                      toggleTopic(subject.id, lesson)
                                                    }}
                                                  >
                                                    <Checkbox
                                                      checked={progress[subject.id]?.[lesson.id] || false}
                                                      className="data-[state=checked]:bg-green-500 data-[state=checked]:border-green-500"
                                                      onCheckedChange={() => {}}
                                                    />
                                                    <div className="flex-1 min-w-0">
                                                      <div className="flex items-center gap-2">
                                                        <span className={`text-sm truncate ${progress[subject.id]?.[lesson.id] ? 'text-green-300 line-through' : 'text-white'}`}>
                                                          {lesson.title}
                                                        </span>
                                                        <Badge className={`text-xs px-1 h-4 ${
                                                          lesson.difficulty === 'easy' ? 'bg-green-500/20 text-green-300' :
                                                          lesson.difficulty === 'medium' ? 'bg-yellow-500/20 text-yellow-300' :
                                                          'bg-red-500/20 text-red-300'
                                                        }`}>
                                                          {lesson.difficulty === 'easy' ? 'Легко' : lesson.difficulty === 'medium' ? 'Средне' : 'Сложно'}
                                                        </Badge>
                                                      </div>
                                                      <p className="text-xs text-gray-500 truncate">{lesson.description}</p>
                                                    </div>
                                                    <div className="flex items-center gap-1 text-xs text-gray-500">
                                                      <Clock className="w-3 h-3" />
                                                      {lesson.estimatedTime} мин
                                                    </div>
                                                    <Button
                                                      size="sm"
                                                      variant="ghost"
                                                      onClick={(e) => {
                                                        e.stopPropagation()
                                                        if (bookmarks.includes(lesson.id)) {
                                                          setBookmarks(prev => prev.filter(id => id !== lesson.id))
                                                        } else {
                                                          setBookmarks(prev => [...prev, lesson.id])
                                                        }
                                                      }}
                                                      className={`h-6 w-6 p-0 ${bookmarks.includes(lesson.id) ? 'text-amber-400' : 'text-white/40 hover:text-amber-400'}`}
                                                    >
                                                      <Bookmark className={`w-3 h-3 ${bookmarks.includes(lesson.id) ? 'fill-current' : ''}`} />
                                                    </Button>
                                                    <Button
                                                      size="sm"
                                                      variant="ghost"
                                                      onClick={(e) => {
                                                        e.stopPropagation()
                                                        setSelectedTopic(topic)
                                                        setSelectedSubjectForTopic(subject)
                                                        setTopicDialogOpen(true)
                                                      }}
                                                      className="h-6 w-6 p-0 text-white/40 hover:text-white"
                                                    >
                                                      <BookOpen className="w-3 h-3" />
                                                    </Button>
                                                  </div>
                                                ))}
                                              </div>
                                            </AccordionContent>
                                          </AccordionItem>
                                        )
                                      })}
                                    </Accordion>
                                  </AccordionContent>
                                </AccordionItem>
                              )
                            })}
                          </Accordion>
                          
                          {subject.quiz && subject.quiz.length > 0 && (
                            <>
                              <Separator className="bg-white/10" />
                              <div className="flex items-center justify-between">
                                <div className="flex items-center gap-2 text-white/60">
                                  <Brain className="w-4 h-4" />
                                  <span className="text-sm">Тест: {subject.quiz.length} вопросов</span>
                                </div>
                                <Button
                                  size="sm"
                                  onClick={() => startQuiz(subject)}
                                  className="bg-gradient-to-r from-lime-600 to-orange-600 hover:from-lime-700 hover:to-orange-700 text-white"
                                >
                                  <Play className="w-4 h-4 mr-1.5" />
                                  Начать тест
                                </Button>
                              </div>
                            </>
                          )}
                        </div>
                      )}
                    </CardContent>
                  </Card>
                )
              })}
            </div>
          </TabsContent>

          {/* Таб ежедневных заданий */}
          <TabsContent value="tasks" className="space-y-4">
            {/* Заголовок заданий */}
            <Card className="bg-gradient-to-br from-cyan-500/20 to-blue-500/20 border-cyan-500/30">
              <CardContent className="p-4">
                <div className="flex items-center justify-between">
                  <div className="flex items-center gap-3">
                    <div className="p-3 rounded-xl bg-cyan-500/20">
                      <Calendar className="w-8 h-8 text-cyan-400" />
                    </div>
                    <div>
                      <h3 className="text-xl font-bold text-white">Ежедневные задания</h3>
                      <p className="text-gray-400">
                        Выполнено: {dailyTasks.filter(t => t.completed).length} из {dailyTasks.length}
                      </p>
                    </div>
                  </div>
                  <div className="text-right">
                    <div className="text-2xl font-bold text-cyan-400">
                      +{dailyTasks.filter(t => t.completed).reduce((sum, t) => sum + t.reward, 0)} XP
                    </div>
                    <p className="text-xs text-gray-400">заработано сегодня</p>
                  </div>
                </div>
                {dailyTasks.every(t => t.completed) && (
                  <div className="mt-4 p-3 rounded-lg bg-gradient-to-r from-green-500/20 to-emerald-500/20 border border-green-500/30 flex items-center gap-3">
                    <Trophy className="w-6 h-6 text-green-400" />
                    <div>
                      <p className="text-green-300 font-medium">Все задания выполнены!</p>
                      <p className="text-xs text-gray-400">Возвращайтесь завтра за новыми заданиями</p>
                    </div>
                  </div>
                )}
              </CardContent>
            </Card>

            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
              {dailyTasks.map(task => (
                <Card
                  key={task.id}
                  className={`${
                    task.completed
                      ? 'bg-green-500/10 border-green-500/30'
                      : 'bg-white/5 border-white/10'
                  } backdrop-blur transition-all hover:scale-[1.02]`}
                >
                  <CardContent className="p-4">
                    <div className="flex flex-col items-center text-center">
                      <div className={`p-3 rounded-xl mb-3 ${task.completed ? 'bg-green-500/20' : 'bg-white/10'}`}>
                        {task.type === 'topics' && <Book className={`w-6 h-6 ${task.completed ? 'text-green-400' : 'text-white/60'}`} />}
                        {task.type === 'quizzes' && <Zap className={`w-6 h-6 ${task.completed ? 'text-green-400' : 'text-white/60'}`} />}
                        {task.type === 'points' && <Star className={`w-6 h-6 ${task.completed ? 'text-green-400' : 'text-white/60'}`} />}
                        {task.type === 'challenges' && <Target className={`w-6 h-6 ${task.completed ? 'text-green-400' : 'text-white/60'}`} />}
                      </div>
                      <h3 className="font-bold text-white mb-1">{task.title}</h3>
                      <p className="text-xs text-gray-400 mb-3">{task.description}</p>
                      <div className="w-full">
                        <div className="flex justify-between text-xs mb-1">
                          <span className="text-gray-400">{task.progress}/{task.target}</span>
                          <span className="text-amber-400 font-medium">+{task.reward} XP</span>
                        </div>
                        <Progress value={(task.progress / task.target) * 100} className="h-2" />
                      </div>
                      {task.completed && (
                        <Badge className="mt-3 bg-green-500/20 text-green-300 border-green-500/30">
                          <CheckCircle className="w-3 h-3 mr-1" />
                          Выполнено
                        </Badge>
                      )}
                    </div>
                  </CardContent>
                </Card>
              ))}
            </div>
          </TabsContent>

          {/* Таб достижений */}
          <TabsContent value="achievements" className="space-y-4">
            {/* Заголовок достижений */}
            <Card className="bg-gradient-to-br from-amber-500/20 to-yellow-500/20 border-amber-500/30">
              <CardContent className="p-4">
                <div className="flex items-center justify-between">
                  <div className="flex items-center gap-3">
                    <div className="p-3 rounded-xl bg-amber-500/20">
                      <Trophy className="w-8 h-8 text-amber-400" />
                    </div>
                    <div>
                      <h3 className="text-xl font-bold text-white">Достижения</h3>
                      <p className="text-gray-400">
                        Разблокировано: {achievements.filter(a => a.unlocked).length} из {achievements.length}
                      </p>
                    </div>
                  </div>
                  <div className="text-right">
                    <div className="text-2xl font-bold text-amber-400">
                      {achievements.filter(a => a.unlocked).reduce((sum, a) => sum + a.points, 0)} XP
                    </div>
                    <p className="text-xs text-gray-400">заработано из достижений</p>
                  </div>
                </div>
                <div className="mt-4">
                  <Progress
                    value={(achievements.filter(a => a.unlocked).length / achievements.length) * 100}
                    className="h-2"
                  />
                </div>
              </CardContent>
            </Card>

            {/* Фильтры по редкости */}
            <div className="flex gap-2 flex-wrap">
              <Badge className="bg-gray-500/20 text-gray-300">
                Обычные: {achievements.filter(a => a.rarity === 'common' && a.unlocked).length}/{achievements.filter(a => a.rarity === 'common').length}
              </Badge>
              <Badge className="bg-blue-500/20 text-blue-300">
                Редкие: {achievements.filter(a => a.rarity === 'rare' && a.unlocked).length}/{achievements.filter(a => a.rarity === 'rare').length}
              </Badge>
              <Badge className="bg-purple-500/20 text-purple-300">
                Эпические: {achievements.filter(a => a.rarity === 'epic' && a.unlocked).length}/{achievements.filter(a => a.rarity === 'epic').length}
              </Badge>
              <Badge className="bg-amber-500/20 text-amber-300">
                Легендарные: {achievements.filter(a => a.rarity === 'legendary' && a.unlocked).length}/{achievements.filter(a => a.rarity === 'legendary').length}
              </Badge>
            </div>

            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
              {achievements.map(achievement => {
                const rarityColors = {
                  common: 'from-gray-500/20 to-gray-600/20 border-gray-500/30',
                  rare: 'from-blue-500/20 to-cyan-500/20 border-blue-500/30',
                  epic: 'from-purple-500/20 to-pink-500/20 border-purple-500/30',
                  legendary: 'from-amber-500/20 to-yellow-500/20 border-amber-500/30'
                }
                const rarityBadge = {
                  common: 'bg-gray-500/20 text-gray-300',
                  rare: 'bg-blue-500/20 text-blue-300',
                  epic: 'bg-purple-500/20 text-purple-300',
                  legendary: 'bg-amber-500/20 text-amber-300'
                }
                
                return (
                  <Card
                    key={achievement.id}
                    className={`${
                      achievement.unlocked
                        ? `bg-gradient-to-br ${rarityColors[achievement.rarity]}`
                        : 'bg-white/5 border-white/10 opacity-50'
                    } backdrop-blur transition-all hover:scale-[1.02]`}
                  >
                    <CardContent className="p-4 text-center">
                      <div className={`mx-auto w-14 h-14 rounded-full flex items-center justify-center mb-3 ${
                        achievement.unlocked ? `bg-gradient-to-br ${rarityColors[achievement.rarity]}` : 'bg-gray-700'
                      }`}>
                        <div className={achievement.unlocked ? 'text-white' : 'text-gray-500'}>
                          {achievement.icon}
                        </div>
                      </div>
                      <h3 className="font-bold text-white mb-1">{achievement.title}</h3>
                      <p className="text-xs text-gray-400 mb-2">{achievement.description}</p>
                      <div className="flex items-center justify-center gap-2">
                        <Badge className={`text-xs ${rarityBadge[achievement.rarity]}`}>
                          {achievement.rarity === 'common' ? 'Обычное' :
                           achievement.rarity === 'rare' ? 'Редкое' :
                           achievement.rarity === 'epic' ? 'Эпическое' : 'Легендарное'}
                        </Badge>
                        <span className="text-xs text-amber-400">+{achievement.points} XP</span>
                      </div>
                      {achievement.unlocked && (
                        <Badge className="mt-2 bg-green-500/20 text-green-300 border-green-500/30">
                          <CheckCircle className="w-3 h-3 mr-1" />
                          Получено
                        </Badge>
                      )}
                    </CardContent>
                  </Card>
                )
              })}
            </div>
          </TabsContent>

          {/* Таб статистики */}
          <TabsContent value="stats" className="space-y-4">
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
              <Card className="bg-gradient-to-br from-purple-500/20 to-blue-500/20 border-purple-500/30">
                <CardContent className="p-4">
                  <div className="flex items-center gap-3">
                    <div className="p-2 rounded-xl bg-purple-500/20">
                      <Book className="w-6 h-6 text-purple-400" />
                    </div>
                    <div>
                      <p className="text-gray-400 text-xs">Изучено тем</p>
                      <p className="text-2xl font-bold text-white">{userStats.topicsCompleted}</p>
                    </div>
                  </div>
                </CardContent>
              </Card>
              
              <Card className="bg-gradient-to-br from-green-500/20 to-emerald-500/20 border-green-500/30">
                <CardContent className="p-4">
                  <div className="flex items-center gap-3">
                    <div className="p-2 rounded-xl bg-green-500/20">
                      <Target className="w-6 h-6 text-green-400" />
                    </div>
                    <div>
                      <p className="text-gray-400 text-xs">Пройдено тестов</p>
                      <p className="text-2xl font-bold text-white">{userStats.quizzesCompleted}</p>
                    </div>
                  </div>
                </CardContent>
              </Card>
              
              <Card className="bg-gradient-to-br from-amber-500/20 to-yellow-500/20 border-amber-500/30">
                <CardContent className="p-4">
                  <div className="flex items-center gap-3">
                    <div className="p-2 rounded-xl bg-amber-500/20">
                      <Star className="w-6 h-6 text-amber-400" />
                    </div>
                    <div>
                      <p className="text-gray-400 text-xs">Всего очков</p>
                      <p className="text-2xl font-bold text-white">{userStats.totalPoints}</p>
                    </div>
                  </div>
                </CardContent>
              </Card>
              
              <Card className="bg-gradient-to-br from-orange-500/20 to-red-500/20 border-orange-500/30">
                <CardContent className="p-4">
                  <div className="flex items-center gap-3">
                    <div className="p-2 rounded-xl bg-orange-500/20">
                      <Flame className="w-6 h-6 text-orange-400" />
                    </div>
                    <div>
                      <p className="text-gray-400 text-xs">Серия дней</p>
                      <p className="text-2xl font-bold text-white">{userStats.streak}</p>
                    </div>
                  </div>
                </CardContent>
              </Card>
            </div>

            {/* Прогресс по классам */}
            <Card className="bg-white/5 border-white/10">
              <CardHeader>
                <CardTitle className="text-white text-lg">Прогресс по классам</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="space-y-3">
                  {schoolData.map(grade => {
                    let total = 0
                    let completed = 0
                    grade.subjects.forEach(subject => {
                      total += subject.topics.length
                      subject.topics.forEach(topic => {
                        if (progress[subject.id]?.[topic.id]) completed++
                      })
                    })
                    const percent = total > 0 ? Math.round((completed / total) * 100) : 0
                    
                    return (
                      <div key={grade.id} className="space-y-1">
                        <div className="flex justify-between text-sm">
                          <span className="text-white">{grade.name}</span>
                          <span className="text-gray-400">{completed}/{total} ({percent}%)</span>
                        </div>
                        <Progress value={percent} className="h-1.5" />
                      </div>
                    )
                  })}
                </div>
              </CardContent>
            </Card>

            {/* Мои заметки */}
            {Object.keys(notes).length > 0 && (
              <Card className="bg-white/5 border-white/10">
                <CardHeader>
                  <CardTitle className="text-white text-lg flex items-center gap-2">
                    <Pencil className="w-5 h-5 text-cyan-400" />
                    Мои заметки
                    <Badge className="bg-cyan-500/20 text-cyan-300 ml-2">
                      {Object.keys(notes).length}
                    </Badge>
                  </CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="space-y-3">
                    {Object.entries(notes).map(([topicId, noteText]) => {
                      let topicInfo: { topic: Topic; subject: Subject; grade: Grade } | null = null
                      schoolData.forEach(grade => {
                        grade.subjects.forEach(subject => {
                          const topic = subject.topics.find(t => t.id === topicId)
                          if (topic) topicInfo = { topic, subject, grade }
                        })
                      })
                      if (!topicInfo || !noteText.trim()) return null
                      
                      return (
                        <div
                          key={topicId}
                          className="p-3 rounded-lg bg-white/5 border border-white/10 cursor-pointer hover:bg-white/10 transition-colors"
                          onClick={() => {
                            setSelectedTopic(topicInfo.topic)
                            setSelectedSubjectForTopic(topicInfo.subject)
                            setTopicDialogOpen(true)
                          }}
                        >
                          <div className="flex items-center gap-2 mb-1">
                            <div className={topicInfo.subject.color}>{topicInfo.subject.icon}</div>
                            <span className="text-white font-medium text-sm">{topicInfo.topic.title}</span>
                            <span className="text-xs text-gray-500">• {topicInfo.grade.shortName}</span>
                          </div>
                          <p className="text-gray-400 text-sm line-clamp-2">{noteText}</p>
                        </div>
                      )
                    })}
                  </div>
                </CardContent>
              </Card>
            )}

            {/* Комбо и рекорды */}
            <Card className="bg-white/5 border-white/10">
              <CardHeader>
                <CardTitle className="text-white text-lg flex items-center gap-2">
                  <Flame className="w-5 h-5 text-amber-400" />
                  Рекорды
                </CardTitle>
              </CardHeader>
              <CardContent>
                <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                  <div className="text-center p-3 rounded-xl bg-amber-500/10 border border-amber-500/20">
                    <Flame className="w-5 h-5 text-amber-400 mx-auto mb-1" />
                    <div className="text-xl font-bold text-amber-400">{maxCombo}</div>
                    <div className="text-xs text-gray-400">Макс. комбо</div>
                  </div>
                  <div className="text-center p-3 rounded-xl bg-green-500/10 border border-green-500/20">
                    <Target className="w-5 h-5 text-green-400 mx-auto mb-1" />
                    <div className="text-xl font-bold text-green-400">{perfectQuizzesCount}</div>
                    <div className="text-xs text-gray-400">Идеальных тестов</div>
                  </div>
                  <div className="text-center p-3 rounded-xl bg-purple-500/10 border border-purple-500/20">
                    <Zap className="w-5 h-5 text-purple-400 mx-auto mb-1" />
                    <div className="text-xl font-bold text-purple-400">{totalChallengesCompleted}</div>
                    <div className="text-xs text-gray-400">Челленджей</div>
                  </div>
                  <div className="text-center p-3 rounded-xl bg-cyan-500/10 border border-cyan-500/20">
                    <Trophy className="w-5 h-5 text-cyan-400 mx-auto mb-1" />
                    <div className="text-xl font-bold text-cyan-400">{userStats.maxStreak}</div>
                    <div className="text-xs text-gray-400">Макс. серия дней</div>
                  </div>
                </div>
              </CardContent>
            </Card>

            {/* История активности */}
            {activityLog.length > 0 && (
              <Card className="bg-white/5 border-white/10">
                <CardHeader>
                  <CardTitle className="text-white text-lg flex items-center gap-2">
                    <Activity className="w-5 h-5 text-green-400" />
                    Последняя активность
                  </CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="space-y-2">
                    {activityLog.slice(0, 10).map(item => (
                      <div
                        key={item.id}
                        className="flex items-center gap-3 p-2 rounded-lg bg-white/5 border border-white/10"
                      >
                        <div className={`p-2 rounded-lg ${
                          item.type === 'topic' ? 'bg-green-500/20' :
                          item.type === 'quiz' ? 'bg-blue-500/20' :
                          item.type === 'achievement' ? 'bg-amber-500/20' :
                          'bg-purple-500/20'
                        }`}>
                          {item.type === 'topic' && <Book className="w-4 h-4 text-green-400" />}
                          {item.type === 'quiz' && <Zap className="w-4 h-4 text-blue-400" />}
                          {item.type === 'achievement' && <Trophy className="w-4 h-4 text-amber-400" />}
                          {item.type === 'streak' && <Flame className="w-4 h-4 text-purple-400" />}
                        </div>
                        <div className="flex-1 min-w-0">
                          <p className="text-white text-sm truncate">{item.title}</p>
                          <p className="text-xs text-gray-400">
                            {new Date(item.timestamp).toLocaleString('ru-RU', {
                              day: 'numeric',
                              month: 'short',
                              hour: '2-digit',
                              minute: '2-digit'
                            })}
                          </p>
                        </div>
                        <div className="text-right">
                          <span className="text-amber-400 text-sm font-medium">+{item.points} XP</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </CardContent>
              </Card>
            )}
          </TabsContent>

          {/* Таб карточек */}
          <TabsContent value="flashcards" className="space-y-4">
            <Card className="bg-white/5 border-white/10">
              <CardHeader>
                <CardTitle className="text-white flex items-center gap-2">
                  <Brain className="w-5 h-5 text-purple-400" />
                  Режим карточек
                </CardTitle>
                <CardDescription className="text-gray-400">
                  Запоминай материал методом интервального повторения. Нажми на карточку, чтобы увидеть ответ.
                </CardDescription>
              </CardHeader>
              <CardContent>
                {!flashcardMode ? (
                  <div className="text-center py-8">
                    <Brain className="w-16 h-16 mx-auto text-purple-400/30 mb-4" />
                    <p className="text-gray-400 mb-4">Карточки помогают запоминать материал методом активного повторения</p>
                    <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                      <div className="p-4 rounded-xl bg-white/5 border border-white/10">
                        <div className="text-2xl mb-2">🔄</div>
                        <h4 className="text-white font-medium">Переворот</h4>
                        <p className="text-xs text-gray-400">Нажмите на карточку, чтобы увидеть ответ</p>
                      </div>
                      <div className="p-4 rounded-xl bg-white/5 border border-white/10">
                        <div className="text-2xl mb-2">✅</div>
                        <h4 className="text-white font-medium">Самооценка</h4>
                        <p className="text-xs text-gray-400">Отметь, знаешь ли ты ответ</p>
                      </div>
                      <div className="p-4 rounded-xl bg-white/5 border border-white/10">
                        <div className="text-2xl mb-2">📊</div>
                        <h4 className="text-white font-medium">Статистика</h4>
                        <p className="text-xs text-gray-400">Отслеживай свой прогресс</p>
                      </div>
                    </div>
                    <Button
                      onClick={startFlashcardMode}
                      className="bg-gradient-to-r from-purple-600 to-blue-600"
                      size="lg"
                    >
                      <Play className="w-5 h-5 mr-2" />
                      Начать учить карточки
                    </Button>
                  </div>
                ) : (
                  <div className="space-y-6">
                    {/* Прогресс */}
                    <div className="flex items-center justify-between">
                      <span className="text-gray-400">Карточка {currentFlashcardIndex + 1} из {flashcards.length}</span>
                      <div className="flex gap-2">
                        <Badge className="bg-green-500/20 text-green-300">✓ {flashcardStats.known}</Badge>
                        <Badge className="bg-red-500/20 text-red-300">✗ {flashcardStats.unknown}</Badge>
                      </div>
                    </div>
                    <Progress value={((currentFlashcardIndex + 1) / flashcards.length) * 100} className="h-2" />
                    
                    {/* Карточка */}
                    <div 
                      className="relative h-64 cursor-pointer perspective-1000"
                      onClick={() => setIsFlipped(!isFlipped)}
                    >
                      <div className={`absolute inset-0 transition-transform duration-500 transform-style-preserve-3d ${isFlipped ? 'rotate-y-180' : ''}`}>
                        {/* Фронт */}
                        <div className="absolute inset-0 backface-hidden">
                          <Card className="h-full bg-gradient-to-br from-purple-500/20 to-blue-500/20 border-purple-500/30 flex items-center justify-center p-6">
                            <div className="text-center">
                              <p className="text-xs text-purple-300 mb-2">{flashcards[currentFlashcardIndex]?.subject}</p>
                              <p className="text-xl text-white font-medium">{flashcards[currentFlashcardIndex]?.question}</p>
                              <p className="text-sm text-gray-400 mt-4">👆 Нажми, чтобы увидеть ответ</p>
                            </div>
                          </Card>
                        </div>
                        {/* Обратная сторона */}
                        <div className="absolute inset-0 backface-hidden rotate-y-180">
                          <Card className="h-full bg-gradient-to-br from-green-500/20 to-emerald-500/20 border-green-500/30 flex items-center justify-center p-6">
                            <div className="text-center">
                              <p className="text-sm text-green-300 mb-2">Ответ:</p>
                              <p className="text-xl text-white font-medium">{flashcards[currentFlashcardIndex]?.answer}</p>
                            </div>
                          </Card>
                        </div>
                      </div>
                    </div>
                    
                    {/* Кнопки */}
                    <div className="flex gap-4">
                      <Button
                        onClick={handleFlashcardUnknown}
                        variant="outline"
                        className="flex-1 bg-red-500/10 border-red-500/30 text-red-300 hover:bg-red-500/20"
                      >
                        <XCircle className="w-5 h-5 mr-2" />
                        Не знаю
                      </Button>
                      <Button
                        onClick={handleFlashcardKnown}
                        className="flex-1 bg-gradient-to-r from-green-600 to-emerald-600"
                      >
                        <CheckCircle className="w-5 h-5 mr-2" />
                        Знаю!
                      </Button>
                    </div>
                    <Button
                      variant="ghost"
                      onClick={() => setFlashcardMode(false)}
                      className="w-full text-gray-400"
                    >
                      Закрыть
                    </Button>
                  </div>
                )}
              </CardContent>
            </Card>
          </TabsContent>

          {/* Таб экзамена */}
          <TabsContent value="exam" className="space-y-4">
            {!examMode ? (
              // Выбор класса и предмета
              <div className="space-y-6">
                {/* Заголовок */}
                <Card className="bg-gradient-to-r from-red-500/10 via-orange-500/10 to-amber-500/10 border-orange-500/20">
                  <CardContent className="p-6">
                    <div className="text-center">
                      <div className="w-20 h-20 mx-auto rounded-2xl bg-gradient-to-br from-red-500 to-orange-500 flex items-center justify-center mb-4 shadow-lg shadow-orange-500/30">
                        <FileText className="w-10 h-10 text-white" />
                      </div>
                      <h2 className="text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-orange-400 mb-2">Проверка знаний</h2>
                      <p className="text-gray-400">Пройдите тестирование по любому предмету и классу</p>
                    </div>
                  </CardContent>
                </Card>

                {/* Кнопки классов */}
                <div className="space-y-3">
                  <h3 className="text-sm font-medium text-gray-400 uppercase tracking-wider flex items-center gap-2">
                    <GraduationCap className="w-4 h-4" />
                    Выберите класс для тестирования
                  </h3>
                  <div className="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-7 gap-2">
                    {schoolData.map(grade => (
                      <button
                        key={grade.id}
                        onClick={() => setExamGrade(grade.id)}
                        className={`relative p-3 rounded-xl transition-all duration-300 transform ${
                          examGrade === grade.id
                            ? 'bg-gradient-to-br from-red-500 to-orange-500 text-white shadow-xl shadow-orange-500/40 scale-105 ring-2 ring-orange-400/50'
                            : 'bg-gradient-to-br from-red-500/10 to-orange-500/10 border border-orange-500/30 text-orange-300 hover:from-red-500/20 hover:to-orange-500/30 hover:border-orange-400/50 hover:scale-[1.02]'
                        }`}
                      >
                        <div className="text-lg font-bold">{grade.shortName}</div>
                        {examGrade === grade.id && (
                          <div className="absolute -top-1 -right-1 w-3 h-3 bg-green-400 rounded-full animate-pulse" />
                        )}
                      </button>
                    ))}
                  </div>
                </div>

                {/* Предметы выбранного класса */}
                {examGrade !== null && (
                  <div className="space-y-4 animate-in fade-in slide-in-from-bottom-4 duration-300">
                    <h3 className="text-sm font-medium text-gray-400 uppercase tracking-wider flex items-center gap-2">
                      <BookOpen className="w-4 h-4" />
                      Предметы • {schoolData.find(g => g.id === examGrade)?.name}
                    </h3>

                    {/* Комплексный экзамен */}
                    <Card className="bg-gradient-to-r from-red-500/15 via-orange-500/15 to-amber-500/15 border-orange-500/30 overflow-hidden relative">
                      <div className="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-orange-500/20 to-transparent rounded-full -translate-y-1/2 translate-x-1/2" />
                      <CardContent className="p-5 relative">
                        <div className="flex items-center justify-between">
                          <div className="flex items-center gap-4">
                            <div className="w-14 h-14 rounded-2xl bg-gradient-to-br from-red-500 via-orange-500 to-amber-500 flex items-center justify-center shadow-lg shadow-orange-500/30">
                              <Trophy className="w-7 h-7 text-white" />
                            </div>
                            <div>
                              <h4 className="text-white font-bold text-lg">Комплексный экзамен</h4>
                              <p className="text-sm text-orange-300/80">Все предметы • До 20 вопросов</p>
                            </div>
                          </div>
                          <Button
                            onClick={() => startExamMode(examGrade, 'all')}
                            className="bg-gradient-to-r from-red-500 via-orange-500 to-amber-500 hover:from-red-600 hover:via-orange-600 hover:to-amber-600 shadow-lg shadow-orange-500/30"
                            size="lg"
                          >
                            <Play className="w-5 h-5 mr-2" />
                            Начать
                          </Button>
                        </div>
                      </CardContent>
                    </Card>

                    {/* Список предметов */}
                    <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                      {schoolData.find(g => g.id === examGrade)?.subjects.filter(s => s.quiz.length > 0).map(subject => (
                        <Card key={subject.id} className="bg-gradient-to-br from-white/5 to-white/[0.02] border-white/10 hover:border-orange-500/30 transition-all cursor-pointer group overflow-hidden">
                          <CardContent className="p-4">
                            <div className="flex items-center justify-between">
                              <div className="flex items-center gap-3">
                                <div className={`w-11 h-11 rounded-xl bg-gradient-to-br from-white/10 to-white/5 flex items-center justify-center ${subject.color} group-hover:scale-110 transition-transform`}>
                                  {subject.icon}
                                </div>
                                <div>
                                  <h4 className="text-white font-medium group-hover:text-orange-300 transition-colors">{subject.title}</h4>
                                  <p className="text-xs text-gray-400 flex items-center gap-1">
                                    <span className="w-1.5 h-1.5 rounded-full bg-orange-500" />
                                    {subject.quiz.length} вопросов
                                  </p>
                                </div>
                              </div>
                              <Button
                                size="sm"
                                onClick={() => startExamMode(examGrade, subject.id)}
                                className="bg-gradient-to-r from-red-500/20 to-orange-500/20 hover:from-red-500 hover:to-orange-500 border border-orange-500/30 hover:border-orange-400"
                              >
                                <Play className="w-3.5 h-3.5" />
                              </Button>
                            </div>
                          </CardContent>
                        </Card>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            ) : showExamResults ? (
              // Результаты экзамена
              <Card className="bg-white/5 border-white/10">
                <CardContent className="p-6">
                  <div className="text-center mb-6">
                    <div className={`w-20 h-20 mx-auto rounded-full flex items-center justify-center mb-4 ${
                      examCorrectAnswers.length >= examQuestions.length * 0.8 
                        ? 'bg-green-500/20' 
                        : examCorrectAnswers.length >= examQuestions.length * 0.5 
                          ? 'bg-yellow-500/20' 
                          : 'bg-red-500/20'
                    }`}>
                      {examCorrectAnswers.length >= examQuestions.length * 0.8 ? (
                        <Trophy className="w-10 h-10 text-green-400" />
                      ) : examCorrectAnswers.length >= examQuestions.length * 0.5 ? (
                        <Medal className="w-10 h-10 text-yellow-400" />
                      ) : (
                        <XCircle className="w-10 h-10 text-red-400" />
                      )}
                    </div>
                    <h2 className="text-2xl font-bold text-white mb-2">
                      {examCorrectAnswers.length >= examQuestions.length * 0.8 
                        ? 'Отлично!' 
                        : examCorrectAnswers.length >= examQuestions.length * 0.5 
                          ? 'Хорошо!' 
                          : 'Попробуй ещё!'}
                    </h2>
                    <p className="text-gray-400">
                      Правильных ответов: {examCorrectAnswers.length} из {examQuestions.length}
                    </p>
                  </div>
                  
                  {/* Статистика */}
                  <div className="grid grid-cols-3 gap-4 mb-6">
                    <div className="text-center p-4 rounded-xl bg-green-500/10 border border-green-500/20">
                      <CheckCircle className="w-6 h-6 text-green-400 mx-auto mb-2" />
                      <div className="text-2xl font-bold text-green-400">{examCorrectAnswers.length}</div>
                      <div className="text-xs text-gray-400">Правильно</div>
                    </div>
                    <div className="text-center p-4 rounded-xl bg-red-500/10 border border-red-500/20">
                      <XCircle className="w-6 h-6 text-red-400 mx-auto mb-2" />
                      <div className="text-2xl font-bold text-red-400">{examQuestions.length - examCorrectAnswers.length}</div>
                      <div className="text-xs text-gray-400">Ошибок</div>
                    </div>
                    <div className="text-center p-4 rounded-xl bg-cyan-500/10 border border-cyan-500/20">
                      <Timer className="w-6 h-6 text-cyan-400 mx-auto mb-2" />
                      <div className="text-2xl font-bold text-cyan-400">
                        {Math.floor(examTimer / 60)}:{(examTimer % 60).toString().padStart(2, '0')}
                      </div>
                      <div className="text-xs text-gray-400">Время</div>
                    </div>
                  </div>
                  
                  {/* Очки */}
                  <div className="text-center p-4 rounded-xl bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/20 mb-6">
                    <Star className="w-6 h-6 text-amber-400 mx-auto mb-2" />
                    <div className="text-3xl font-bold text-amber-400">+{examCorrectAnswers.length * 15} XP</div>
                    <div className="text-xs text-gray-400">заработано очков</div>
                  </div>
                  
                  <Button
                    onClick={finishExam}
                    className="w-full bg-gradient-to-r from-green-600 to-emerald-600"
                    size="lg"
                  >
                    <CheckCircle className="w-5 h-5 mr-2" />
                    Завершить
                  </Button>
                </CardContent>
              </Card>
            ) : (
              // Процесс экзамена
              <Card className="bg-white/5 border-white/10">
                <CardContent className="p-6">
                  <div className="space-y-6">
                    {/* Заголовок с таймером */}
                    <div className="flex items-center justify-between">
                      <div>
                        <h3 className="text-white font-medium">
                          {examSubject === 'all' ? 'Комплексный экзамен' : schoolData.find(g => g.id === examGrade)?.subjects.find(s => s.id === examSubject)?.title}
                        </h3>
                        <p className="text-sm text-gray-400">Вопрос {examAnswers.length + 1} из {examQuestions.length}</p>
                      </div>
                      <div className="flex items-center gap-2 px-3 py-1.5 rounded-xl bg-white/5 border border-white/10">
                        <Timer className="w-4 h-4 text-cyan-400" />
                        <span className="font-mono text-cyan-400">
                          {Math.floor(examTimer / 60).toString().padStart(2, '0')}:
                          {(examTimer % 60).toString().padStart(2, '0')}
                        </span>
                      </div>
                    </div>
                    
                    {/* Прогресс */}
                    <div className="flex gap-1">
                      {examQuestions.map((_, i) => (
                        <div
                          key={i}
                          className={`h-1.5 flex-1 rounded-full transition-all ${
                            i < examAnswers.length 
                              ? examCorrectAnswers.includes(i) ? 'bg-green-500' : 'bg-red-500'
                              : 'bg-white/10'
                          }`}
                        />
                      ))}
                    </div>
                    
                    {/* Текущий вопрос */}
                    {examAnswers.length < examQuestions.length && (
                      <>
                        <div className="p-4 rounded-xl bg-gradient-to-r from-red-500/10 to-orange-500/10 border border-orange-500/20">
                          <p className="text-lg text-white font-medium">
                            {examQuestions[examAnswers.length]?.question}
                          </p>
                        </div>
                        
                        <div className="space-y-2">
                          {examQuestions[examAnswers.length]?.options.map((option, index) => (
                            <button
                              key={index}
                              onClick={() => handleExamAnswer(index)}
                              className="w-full p-3 rounded-xl bg-white/5 hover:bg-gradient-to-r hover:from-red-500/20 hover:to-orange-500/20 border border-white/10 hover:border-orange-500/30 text-left transition-all"
                            >
                              <div className="flex items-center gap-3">
                                <span className="w-7 h-7 rounded-full bg-gradient-to-br from-red-500/20 to-orange-500/20 flex items-center justify-center text-sm font-medium text-orange-300 shrink-0">
                                  {String.fromCharCode(65 + index)}
                                </span>
                                <span className="text-white">{option}</span>
                              </div>
                            </button>
                          ))}
                        </div>
                      </>
                    )}
                    
                    {/* Кнопки */}
                    <div className="flex gap-4">
                      <Button
                        variant="outline"
                        onClick={() => {
                          setExamMode(false)
                          setExamAnswers([])
                          setExamCorrectAnswers([])
                          setExamTimer(0)
                        }}
                        className="flex-1 bg-white/5 border-white/10"
                      >
                        Прервать
                      </Button>
                    </div>
                  </div>
                </CardContent>
              </Card>
            )}
          </TabsContent>

          {/* Таб челленджа */}
          <TabsContent value="challenge" className="space-y-4">
            <Card className="bg-gradient-to-br from-amber-500/10 to-orange-500/10 border-amber-500/20">
              <CardHeader>
                <CardTitle className="text-white flex items-center gap-2">
                  <Zap className="w-5 h-5 text-amber-400" />
                  Ежедневный челлендж
                </CardTitle>
                <CardDescription className="text-gray-400">
                  Выполни задание дня и получи бонусные очки!
                </CardDescription>
              </CardHeader>
              <CardContent>
                {!challengeMode ? (
                  <div className="space-y-6">
                    {/* Статус челленджа */}
                    {dailyChallengeDone ? (
                      <div className="text-center py-8">
                        <div className="w-20 h-20 mx-auto rounded-full bg-green-500/20 flex items-center justify-center mb-4">
                          <CheckCircle className="w-10 h-10 text-green-400" />
                        </div>
                        <h3 className="text-xl text-white font-medium mb-2">Челлендж выполнен!</h3>
                        <p className="text-gray-400">Приходи завтра за новым заданием</p>
                      </div>
                    ) : (
                      <div className="text-center py-8">
                        <div className="w-20 h-20 mx-auto rounded-full bg-gradient-to-br from-amber-500/20 to-orange-500/20 flex items-center justify-center mb-4">
                          <Zap className="w-10 h-10 text-amber-400" />
                        </div>
                        <h3 className="text-xl text-white font-medium mb-2">Челлендж дня</h3>
                        <p className="text-gray-400 mb-6">Ответь на 10 случайных вопросов из всех предметов</p>
                        <Button
                          onClick={startDailyChallenge}
                          size="lg"
                          className="bg-gradient-to-r from-amber-600 to-orange-600"
                        >
                          <Play className="w-5 h-5 mr-2" />
                          Начать челлендж
                        </Button>
                      </div>
                    )}
                    
                    {/* Ежедневные цели */}
                    <div className="space-y-3 pt-4 border-t border-white/10">
                      <h4 className="text-white font-medium flex items-center gap-2">
                        <Target className="w-4 h-4 text-purple-400" />
                        Ежедневные цели
                      </h4>
                      <div className="p-4 rounded-xl bg-white/5 border border-white/10">
                        <div className="flex items-center justify-between mb-2">
                          <span className="text-white font-medium">Изучи 5 новых тем сегодня</span>
                          <Badge className="bg-amber-500/20 text-amber-300">+100 XP</Badge>
                        </div>
                        <Progress value={Math.min((dailyStats.topicsToday / 5) * 100, 100)} className="h-2" />
                        <p className="text-xs text-gray-400 mt-2">{dailyStats.topicsToday}/5 тем</p>
                      </div>
                      
                      <div className="p-4 rounded-xl bg-white/5 border border-white/10">
                        <div className="flex items-center justify-between mb-2">
                          <span className="text-white font-medium">Пройди 3 теста</span>
                          <Badge className="bg-green-500/20 text-green-300">+75 XP</Badge>
                        </div>
                        <Progress value={Math.min((dailyStats.quizzesToday / 3) * 100, 100)} className="h-2" />
                        <p className="text-xs text-gray-400 mt-2">{dailyStats.quizzesToday}/3 тестов</p>
                      </div>
                      
                      <div className="p-4 rounded-xl bg-white/5 border border-white/10">
                        <div className="flex items-center justify-between mb-2">
                          <span className="text-white font-medium">Набери 200 XP за день</span>
                          <Badge className="bg-blue-500/20 text-blue-300">+50 XP</Badge>
                        </div>
                        <Progress value={Math.min((dailyStats.pointsToday / 200) * 100, 100)} className="h-2" />
                        <p className="text-xs text-gray-400 mt-2">{dailyStats.pointsToday}/200 XP</p>
                      </div>
                    </div>
                  </div>
                ) : (
                  <div className="space-y-6">
                    {/* Прогресс */}
                    <div className="flex items-center justify-between">
                      <span className="text-gray-400">Вопрос {challengeIndex + 1} из {challengeQuestions.length}</span>
                      <Badge className="bg-amber-500/20 text-amber-300">
                        <Star className="w-3 h-3 mr-1" />
                        {challengeScore} очков
                      </Badge>
                    </div>
                    <Progress value={((challengeIndex + 1) / challengeQuestions.length) * 100} className="h-2" />
                    
                    {/* Вопрос */}
                    <div className="p-4 rounded-xl bg-white/5 border border-white/10">
                      <p className="text-lg text-white font-medium">
                        {challengeQuestions[challengeIndex]?.question}
                      </p>
                    </div>
                    
                    {/* Варианты ответов */}
                    <div className="space-y-2">
                      {challengeQuestions[challengeIndex]?.options.map((option, index) => (
                        <button
                          key={index}
                          onClick={() => handleChallengeAnswer(index)}
                          className="w-full p-3 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 text-left transition-all"
                        >
                          <div className="flex items-center gap-3">
                            <span className="w-7 h-7 rounded-full bg-amber-500/20 flex items-center justify-center text-sm font-medium text-amber-300 shrink-0">
                              {String.fromCharCode(65 + index)}
                            </span>
                            <span className="text-white">{option}</span>
                          </div>
                        </button>
                      ))}
                    </div>
                    
                    {challengeCompleted && (
                      <div className="text-center py-4">
                        <h3 className="text-xl text-white font-medium mb-2">Челлендж завершён!</h3>
                        <p className="text-amber-400">Ты заработал {challengeScore * 10 + 50} XP</p>
                        <Button
                          onClick={() => setChallengeMode(false)}
                          className="mt-4 bg-gradient-to-r from-amber-600 to-orange-600"
                        >
                          Закрыть
                        </Button>
                      </div>
                    )}
                    
                    <Button
                      variant="ghost"
                      onClick={() => setChallengeMode(false)}
                      className="w-full text-gray-400"
                    >
                      Выйти
                    </Button>
                  </div>
                )}
              </CardContent>
            </Card>
          </TabsContent>

          {/* Таб избранного */}
          <TabsContent value="bookmarks" className="space-y-4">
            <Card className="bg-white/5 border-white/10">
              <CardHeader>
                <CardTitle className="text-white flex items-center gap-2">
                  <Bookmark className="w-5 h-5 text-amber-400" />
                  Избранные темы
                </CardTitle>
                <CardDescription className="text-gray-400">
                  {bookmarks.length > 0 ? `Сохранено: ${bookmarks.length} тем` : 'Пока нет избранных тем'}
                </CardDescription>
              </CardHeader>
              <CardContent>
                {bookmarks.length > 0 ? (
                  <div className="space-y-2">
                    {bookmarks.map(bookmarkId => {
                      let topicInfo: { topic: Topic, subject: Subject, grade: Grade } | null = null
                      schoolData.forEach(grade => {
                        grade.subjects.forEach(subject => {
                          const topic = subject.topics.find(t => t.id === bookmarkId)
                          if (topic) topicInfo = { topic, subject, grade }
                        })
                      })
                      if (!topicInfo) return null
                      const isCompleted = progress[topicInfo.subject.id]?.[topicInfo.topic.id]
                      
                      return (
                        <div 
                          key={bookmarkId} 
                          className={`flex items-center gap-3 p-3 rounded-lg border transition-all cursor-pointer hover:bg-white/10 ${
                            isCompleted 
                              ? 'bg-green-500/10 border-green-500/20' 
                              : 'bg-white/5 border-white/10'
                          }`}
                          onClick={() => {
                            setSelectedTopic(topicInfo.topic)
                            setSelectedSubjectForTopic(topicInfo.subject)
                            setTopicDialogOpen(true)
                          }}
                        >
                          <div className="flex items-center justify-center w-8 h-8 rounded-lg bg-white/10 shrink-0">
                            {isCompleted ? (
                              <CheckCircle className="w-4 h-4 text-green-400" />
                            ) : (
                              <div className={topicInfo.subject.color}>{topicInfo.subject.icon}</div>
                            )}
                          </div>
                          <div className="flex-1 min-w-0">
                            <div className="flex items-center gap-2">
                              <p className={`text-white truncate ${isCompleted ? 'line-through text-green-300' : ''}`}>
                                {topicInfo.topic.title}
                              </p>
                              <Badge className={`text-xs px-1.5 h-5 shrink-0 ${
                                topicInfo.topic.difficulty === 'easy' ? 'bg-green-500/20 text-green-300' :
                                topicInfo.topic.difficulty === 'medium' ? 'bg-yellow-500/20 text-yellow-300' :
                                'bg-red-500/20 text-red-300'
                              }`}>
                                {topicInfo.topic.difficulty === 'easy' ? 'Легко' : topicInfo.topic.difficulty === 'medium' ? 'Средне' : 'Сложно'}
                              </Badge>
                            </div>
                            <div className="flex items-center gap-2 text-xs text-gray-400">
                              <span>{topicInfo.subject.title}</span>
                              <span>•</span>
                              <span>{topicInfo.grade.shortName}</span>
                              {topicInfo.topic.estimatedTime > 0 && (
                                <>
                                  <span>•</span>
                                  <span className="flex items-center gap-1">
                                    <Clock className="w-3 h-3" />
                                    {topicInfo.topic.estimatedTime} мин
                                  </span>
                                </>
                              )}
                            </div>
                          </div>
                          <Button
                            size="sm"
                            variant="ghost"
                            onClick={(e) => {
                              e.stopPropagation()
                              setBookmarks(prev => prev.filter(id => id !== bookmarkId))
                            }}
                            className="text-gray-400 hover:text-red-400 shrink-0"
                          >
                            <X className="w-4 h-4" />
                          </Button>
                        </div>
                      )
                    })}
                  </div>
                ) : (
                  <div className="text-center py-12">
                    <Bookmark className="w-16 h-16 mx-auto text-amber-400/30 mb-4" />
                    <p className="text-gray-400">Добавляйте темы в избранное для быстрого доступа</p>
                  </div>
                )}
              </CardContent>
            </Card>
          </TabsContent>
        </Tabs>
      </div>

      {/* Диалог квиза */}
      <Dialog open={quizDialogOpen} onOpenChange={setQuizDialogOpen}>
        <DialogContent className="bg-slate-900 border-white/10 text-white max-w-lg">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2 text-lg">
              <Zap className="w-5 h-5 text-yellow-400" />
              Тест: {currentQuizSubject}
            </DialogTitle>
            <DialogDescription className="text-gray-400">
              Вопрос {currentQuestionIndex + 1} из {currentQuiz.length}
            </DialogDescription>
          </DialogHeader>
          
          {currentQuiz.length > 0 && (
            <div className="space-y-4">
              {/* Прогресс квиза */}
              <div className="flex gap-1">
                {currentQuiz.map((_, i) => (
                  <div
                    key={i}
                    className={`h-1 flex-1 rounded-full ${
                      i < currentQuestionIndex ? 'bg-green-500' :
                      i === currentQuestionIndex ? 'bg-purple-500' : 'bg-white/10'
                    }`}
                  />
                ))}
              </div>
              
              <div className="p-4 rounded-xl bg-white/5 border border-white/10">
                <p className="text-lg font-medium text-white">
                  {currentQuiz[currentQuestionIndex].question}
                </p>
              </div>
              
              <div className="space-y-2">
                {currentQuiz[currentQuestionIndex].options.map((option, index) => {
                  const isSelected = selectedAnswer === index
                  const isCorrect = index === currentQuiz[currentQuestionIndex].correctAnswer
                  let bgClass = 'bg-white/5 hover:bg-white/10 border-white/10'
                  
                  if (showResult) {
                    if (isCorrect) bgClass = 'bg-green-500/20 border-green-500/30'
                    else if (isSelected && !isCorrect) bgClass = 'bg-red-500/20 border-red-500/30'
                  }
                  
                  return (
                    <button
                      key={index}
                      onClick={() => answerQuestion(index)}
                      disabled={showResult}
                      className={`w-full p-3 rounded-xl border text-left transition-all ${bgClass}`}
                    >
                      <div className="flex items-center gap-3">
                        <span className="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-sm font-medium shrink-0">
                          {String.fromCharCode(65 + index)}
                        </span>
                        <span className="text-white">{option}</span>
                        {showResult && isCorrect && (
                          <CheckCircle className="w-5 h-5 text-green-400 ml-auto" />
                        )}
                        {showResult && isSelected && !isCorrect && (
                          <XCircle className="w-5 h-5 text-red-400 ml-auto" />
                        )}
                      </div>
                    </button>
                  )
                })}
              </div>
              
              {showResult && (
                <div className={`p-3 rounded-xl text-sm ${
                  selectedAnswer === currentQuiz[currentQuestionIndex].correctAnswer
                    ? 'bg-green-500/10 border border-green-500/20'
                    : 'bg-red-500/10 border border-red-500/20'
                }`}>
                  <p className="font-medium mb-1">
                    {selectedAnswer === currentQuiz[currentQuestionIndex].correctAnswer
                      ? '✓ Правильно!'
                      : '✗ Неправильно'}
                  </p>
                  <p className="text-gray-400">{currentQuiz[currentQuestionIndex].explanation}</p>
                </div>
              )}
              
              {showResult && (
                <Button
                  onClick={nextQuestion}
                  className="w-full bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700"
                >
                  {currentQuestionIndex < currentQuiz.length - 1 ? 'Следующий вопрос' : 'Завершить тест'}
                </Button>
              )}
            </div>
          )}
        </DialogContent>
      </Dialog>

      {/* Диалог теории */}
      <Dialog open={topicDialogOpen} onOpenChange={setTopicDialogOpen}>
        <DialogContent className="bg-slate-900 border-white/10 text-white max-w-2xl max-h-[80vh] overflow-hidden">
          <DialogHeader>
            <div className="flex items-center justify-between">
              <DialogTitle className="flex items-center gap-2">
                <BookOpen className="w-5 h-5 text-purple-400" />
                {selectedTopic?.title}
              </DialogTitle>
              {selectedTopic && (
                <Button
                  variant="ghost"
                  size="icon"
                  onClick={() => {
                    const topicId = selectedTopic.id
                    if (bookmarks.includes(topicId)) {
                      setBookmarks(prev => prev.filter(id => id !== topicId))
                    } else {
                      setBookmarks(prev => [...prev, topicId])
                    }
                  }}
                  className={bookmarks.includes(selectedTopic.id) ? "text-amber-400" : "text-gray-400 hover:text-amber-400"}
                >
                  <Bookmark className={`w-5 h-5 ${bookmarks.includes(selectedTopic.id) ? 'fill-current' : ''}`} />
                </Button>
              )}
            </div>
            <DialogDescription className="text-gray-400">
              {selectedTopic?.description}
            </DialogDescription>
          </DialogHeader>
          
          <ScrollArea className="h-[50vh]">
            {selectedTopic && (
              <div className="space-y-4 pr-4">
                <div 
                  className="prose prose-invert prose-sm max-w-none"
                  dangerouslySetInnerHTML={{ __html: selectedTopic.theory }}
                />
                
                {selectedTopic.examples.length > 0 && (
                  <div className="space-y-2">
                    <h4 className="text-white font-medium">Примеры:</h4>
                    <ul className="space-y-1">
                      {selectedTopic.examples.map((example, i) => (
                        <li key={i} className="flex items-center gap-2 text-gray-300">
                          <ChevronRight className="w-4 h-4 text-purple-400" />
                          {example}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {/* Секция заметок */}
                <div className="space-y-2 pt-4 border-t border-white/10">
                  <div className="flex items-center gap-2">
                    <Pencil className="w-4 h-4 text-cyan-400" />
                    <h4 className="text-white font-medium">Мои заметки</h4>
                  </div>
                  <textarea
                    value={notes[selectedTopic.id] || ''}
                    onChange={(e) => {
                      setNotes(prev => ({
                        ...prev,
                        [selectedTopic.id]: e.target.value
                      }))
                    }}
                    placeholder="Добавьте свои заметки по этой теме..."
                    className="w-full h-24 p-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-gray-500 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50"
                  />
                  <div className="flex items-center justify-between text-xs text-gray-500">
                    <span>Заметки сохраняются автоматически</span>
                    <span>{(notes[selectedTopic.id] || '').length} символов</span>
                  </div>
                </div>
              </div>
            )}
          </ScrollArea>
          
          <DialogFooter className="flex-col sm:flex-row gap-2">
            {selectedSubjectForTopic && selectedSubjectForTopic.quiz && selectedSubjectForTopic.quiz.length > 0 && (
              <Button
                onClick={() => {
                  setTopicDialogOpen(false)
                  startQuiz(selectedSubjectForTopic)
                }}
                className="w-full sm:w-auto bg-gradient-to-r from-lime-600 to-orange-600 hover:from-lime-700 hover:to-orange-700 text-white"
              >
                <Brain className="w-4 h-4 mr-2" />
                Тест
              </Button>
            )}
            <Button
              onClick={() => {
                if (selectedTopic) {
                  // Находим subject_id для этой темы
                  for (const grade of schoolData) {
                    for (const subject of grade.subjects) {
                      if (subject.topics.find(t => t.id === selectedTopic.id)) {
                        toggleTopic(subject.id, selectedTopic)
                        break
                      }
                    }
                  }
                }
                setTopicDialogOpen(false)
              }}
              className="w-full sm:w-auto bg-gradient-to-r from-green-600 to-emerald-600"
            >
              <CheckCircle className="w-4 h-4 mr-2" />
              Отметить как изученное
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Диалог клавиатурных сокращений */}
      <Dialog open={showShortcuts} onOpenChange={setShowShortcuts}>
        <DialogContent className="bg-slate-900 border-white/10 text-white max-w-md">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2">
              <Keyboard className="w-5 h-5 text-purple-400" />
              Клавиатурные сокращения
            </DialogTitle>
            <DialogDescription className="text-gray-400">
              Быстрые клавиши для удобной навигации
            </DialogDescription>
          </DialogHeader>
          
          <div className="space-y-4">
            <div className="space-y-2">
              <h4 className="text-sm font-medium text-purple-300">Навигация по классам</h4>
              <div className="grid grid-cols-2 gap-2 text-sm">
                <div className="flex items-center gap-2">
                  <kbd className="px-2 py-1 rounded bg-white/10 text-xs">0</kbd>
                  <span className="text-gray-300">Подг. класс</span>
                </div>
                <div className="flex items-center gap-2">
                  <kbd className="px-2 py-1 rounded bg-white/10 text-xs">1-9</kbd>
                  <span className="text-gray-300">1-9 класс</span>
                </div>
              </div>
            </div>
            
            <Separator className="bg-white/10" />
            
            <div className="space-y-2">
              <h4 className="text-sm font-medium text-purple-300">Вкладки</h4>
              <div className="grid grid-cols-2 gap-2 text-sm">
                <div className="flex items-center gap-2">
                  <kbd className="px-2 py-1 rounded bg-white/10 text-xs">T</kbd>
                  <span className="text-gray-300">Предметы</span>
                </div>
                <div className="flex items-center gap-2">
                  <kbd className="px-2 py-1 rounded bg-white/10 text-xs">A</kbd>
                  <span className="text-gray-300">Задания</span>
                </div>
                <div className="flex items-center gap-2">
                  <kbd className="px-2 py-1 rounded bg-white/10 text-xs">C</kbd>
                  <span className="text-gray-300">Достижения</span>
                </div>
                <div className="flex items-center gap-2">
                  <kbd className="px-2 py-1 rounded bg-white/10 text-xs">S</kbd>
                  <span className="text-gray-300">Статистика</span>
                </div>
              </div>
            </div>
            
            <Separator className="bg-white/10" />
            
            <div className="space-y-2">
              <h4 className="text-sm font-medium text-purple-300">Разное</h4>
              <div className="grid grid-cols-2 gap-2 text-sm">
                <div className="flex items-center gap-2">
                  <kbd className="px-2 py-1 rounded bg-white/10 text-xs">?</kbd>
                  <span className="text-gray-300">Справка</span>
                </div>
                <div className="flex items-center gap-2">
                  <kbd className="px-2 py-1 rounded bg-white/10 text-xs">Esc</kbd>
                  <span className="text-gray-300">Закрыть</span>
                </div>
              </div>
            </div>
          </div>
        </DialogContent>
      </Dialog>

      {/* Диалог настроек */}
      <Dialog open={showSettings} onOpenChange={setShowSettings}>
        <DialogContent className="bg-slate-900 border-white/10 text-white max-w-md">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2">
              <Settings className="w-5 h-5 text-gray-400" />
              Настройки
            </DialogTitle>
            <DialogDescription className="text-gray-400">
              Настройте приложение под себя
            </DialogDescription>
          </DialogHeader>
          
          <div className="space-y-6">
            {/* Звук */}
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-3">
                {soundEnabled ? (
                  <Volume2 className="w-5 h-5 text-cyan-400" />
                ) : (
                  <VolumeX className="w-5 h-5 text-gray-500" />
                )}
                <div>
                  <p className="text-white">Звуковые эффекты</p>
                  <p className="text-xs text-gray-400">Уведомления и звуки</p>
                </div>
              </div>
              <Button
                variant="outline"
                size="sm"
                onClick={() => setSoundEnabled(!soundEnabled)}
                className={soundEnabled ? 'bg-cyan-500/20 border-cyan-500/30 text-cyan-300' : 'bg-white/5 border-white/10 text-gray-400'}
              >
                {soundEnabled ? 'Вкл' : 'Выкл'}
              </Button>
            </div>
            
            <Separator className="bg-white/10" />
            
            {/* Заморозки стрика */}
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-3">
                <span className="text-xl">❄️</span>
                <div>
                  <p className="text-white">Заморозки стрика</p>
                  <p className="text-xs text-gray-400">Сохраняют серию при пропуске дня</p>
                </div>
              </div>
              <Badge className="bg-cyan-500/20 text-cyan-300">{streakFreeze} шт</Badge>
            </div>
            
            <Separator className="bg-white/10" />
            
            {/* Сброс прогресса */}
            <div>
              <p className="text-white mb-2">Сброс данных</p>
              <Button
                variant="outline"
                size="sm"
                onClick={() => {
                  if (confirm('Вы уверены? Все данные будут удалены!')) {
                    localStorage.clear()
                    window.location.reload()
                  }
                }}
                className="bg-red-500/10 border-red-500/30 text-red-400 hover:bg-red-500/20"
              >
                <RotateCcw className="w-4 h-4 mr-2" />
                Сбросить всё
              </Button>
            </div>
          </div>
        </DialogContent>
      </Dialog>

      {/* Стили для анимации конфетти и карточек */}
      <style jsx global>{`
        @keyframes fall {
          0% {
            transform: translateY(0) rotate(0deg);
            opacity: 1;
          }
          100% {
            transform: translateY(100vh) rotate(720deg);
            opacity: 0;
          }
        }
        .animate-fall {
          animation: fall linear forwards;
        }
        
        /* Стили для переворота карточек */
        .perspective-1000 {
          perspective: 1000px;
        }
        .transform-style-preserve-3d {
          transform-style: preserve-3d;
        }
        .backface-hidden {
          backface-visibility: hidden;
        }
        .rotate-y-180 {
          transform: rotateY(180deg);
        }
        
        .prose h3 {
          color: white;
          font-size: 1.1rem;
          font-weight: 600;
          margin-top: 1rem;
          margin-bottom: 0.5rem;
        }
        .prose h4 {
          color: rgba(255,255,255,0.9);
          font-size: 1rem;
          font-weight: 500;
          margin-top: 0.75rem;
          margin-bottom: 0.25rem;
        }
        .prose p {
          color: rgba(255,255,255,0.8);
          line-height: 1.6;
        }
        .prose ul, .prose ol {
          color: rgba(255,255,255,0.8);
          padding-left: 1.5rem;
        }
        .prose li {
          margin: 0.25rem 0;
        }
        .prose pre {
          background: rgba(255,255,255,0.05);
          padding: 0.5rem;
          border-radius: 0.5rem;
          font-family: monospace;
        }
      `}</style>
    </div>
  )
}
