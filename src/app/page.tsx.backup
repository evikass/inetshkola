// Функция преобразования плоских тем в иерархическую структуру
function convertToHierarchy(legacyData: GradeLegacy[]): Grade[] {
  return legacyData.map(grade => ({
    ...grade,
    subjects: grade.subjects.map(subject => {
      const rules = subjectGroupingRules[subject.id]
      
      if (!rules || !rules.sections.length) {
        // Если правил нет, создаём один раздел с одной темой
        return {
          ...subject,
          sections: [{
            id: `${subject.id}-section-main`,
            title: 'Основные темы',
            description: subject.description,
            topics: [{
              id: `${subject.id}-topic-main`,
              title: subject.title,
              description: subject.description,
              lessons: subject.topics.map(t => ({ ...t }))
            }]
          }]
        }
      }

      // Группируем темы по разделам
      const sections: Section[] = rules.sections.map((sectionRule, sectionIndex) => {
        // Находим все темы, которые подходят под ключевые слова этого раздела
        const matchedTopics = subject.topics.filter(topic => 
          sectionRule.topicKeywords.some(keywords => 
            keywords.some(keyword => 
              topic.title.toLowerCase().includes(keyword.toLowerCase()) ||
              topic.description.toLowerCase().includes(keyword.toLowerCase())
            )
          )
        )

        // Группируем matchedTopics по темам (2-4 урока в теме)
        const topics: Topic[] = []
        const lessonsPerTopic = 3
        
        for (let i = 0; i < matchedTopics.length; i += lessonsPerTopic) {
          const lessonsSlice = matchedTopics.slice(i, i + lessonsPerTopic)
          if (lessonsSlice.length > 0) {
            topics.push({
              id: `${subject.id}-topic-${sectionIndex}-${i / lessonsPerTopic}`,
              title: lessonsSlice[0].title.replace(/Урок \d+:?\s*/i, '').replace(/^\d+\.\s*/, ''),
              description: lessonsSlice[0].description,
              lessons: lessonsSlice.map(l => ({ ...l }))
            })
          }
        }

        // Если нет подходящих тем, создаём тему с одним уроком
        if (topics.length === 0 && matchedTopics.length === 0) {
          // Берём темы, которые не попали в другие разделы
        }

        return {
          id: `${subject.id}-section-${sectionIndex}`,
          title: sectionRule.title,
          description: sectionRule.description,
          topics
        }
      })

      // Добавляем раздел "Прочее" для тем, которые не попали ни в один раздел
      const usedTopicIds = new Set(sections.flatMap(s => s.topics.flatMap(t => t.lessons.map(l => l.id))))
      const unusedTopics = subject.topics.filter(t => !usedTopicIds.has(t.id))
      
      if (unusedTopics.length > 0) {
        sections.push({
          id: `${subject.id}-section-other`,
          title: 'Дополнительные темы',
          description: 'Другие темы предмета',
          topics: [{
            id: `${subject.id}-topic-other`,
            title: 'Дополнительные уроки',
            description: 'Дополнительные темы для изучения',
            lessons: unusedTopics.map(l => ({ ...l }))
          }]
        })
      }

      // Убираем пустые разделы
      const nonEmptySections = sections.filter(s => s.topics.length > 0 && s.topics.some(t => t.lessons.length > 0))

      // Если все разделы пустые, создаём дефолтную структуру
      if (nonEmptySections.length === 0) {
        return {
          ...subject,
          sections: [{
            id: `${subject.id}-section-main`,
            title: 'Основные темы',
            description: subject.description,
            topics: [{
              id: `${subject.id}-topic-main`,
              title: subject.title,
              description: subject.description,
              lessons: subject.topics.map(t => ({ ...t }))
            }]
          }]
        }
      }

      return {
        ...subject,
        sections: nonEmptySections
      }
    })
  }))
}

